---
<aside class="hidden md:flex flex-col w-[320px] sticky top-24 gap-4 items-center">
  <!-- AdSense Top -->
  <div class="w-[300px] h-[250px] bg-primary-600 border-2 border-dashed border-slate-400 flex items-center justify-center text-slate-100 rounded-xl relative overflow-hidden">
    Advertisement
  </div>

  <!-- Affiliate Card 1 -->
  <div class="w-[300px] bg-primary-600 rounded-xl p-4 flex flex-col gap-3">
    <div class="w-full h-[80px] bg-primary-700 flex items-center justify-center text-slate-100 font-bold rounded-lg truncate">
      Interactive Brokers
    </div>
    <div>
      <h3 class="text-slate-100 font-bold text-lg">Interactive Brokers</h3>
      <div class="text-accent-500 text-sm tracking-widest my-1">★★★★★</div>
      <p class="text-slate-400 text-sm leading-snug">Best broker for international investors. 200+ countries, lowest FX rates.</p>
    </div>
    <div class="mt-1">
      <a href="/best-brokers" class="block w-full bg-accent-500 text-black font-bold text-center py-2 rounded-lg hover:bg-accent-400 transition-colors">Compare Best Brokers</a>
      <p class="text-slate-400 text-[11px] text-center mt-2">Affiliate link — we may earn a commission</p>
    </div>
  </div>

  <!-- Affiliate Card 2 -->
  <div class="w-[300px] bg-primary-600 rounded-xl p-4 flex flex-col gap-3">
    <div class="w-full h-[80px] bg-primary-700 flex items-center justify-center text-slate-100 font-bold rounded-lg truncate">
      tastytrade
    </div>
    <div>
      <h3 class="text-slate-100 font-bold text-lg">tastytrade</h3>
      <div class="text-accent-500 text-sm tracking-widest my-1">★★★★½</div>
      <p class="text-slate-400 text-sm leading-snug">Best for options income strategies. $0 to close all options trades.</p>
    </div>
    <div class="mt-1">
      <a href="#" class="block w-full bg-accent-500 text-black font-bold text-center py-2 rounded-lg hover:bg-accent-400 transition-colors">Start Trading Options</a>
      <p class="text-slate-400 text-[11px] text-center mt-2">Affiliate link — we may earn a commission</p>
    </div>
  </div>

  <!-- AdSense Middle -->
  <div class="w-[300px] h-[250px] bg-primary-600 border-2 border-dashed border-slate-400 flex items-center justify-center text-slate-100 rounded-xl relative overflow-hidden">
    Advertisement
  </div>

  <!-- Featured Tools -->
  <div class="w-[300px] bg-primary-600 rounded-xl p-4">
    <h3 class="text-slate-100 font-bold text-lg pb-2 relative mb-4">
      Our Top Tools
      <span class="absolute bottom-0 left-0 w-10 border-b-2 border-accent-500"></span>
    </h3>
    <ul class="space-y-3">
      <li class="flex items-start">
        <span class="text-accent-500 mr-2 mt-0.5">•</span>
        <div>
          <span class="text-slate-100 font-bold block text-sm">Interactive Brokers</span>
          <span class="text-slate-400 text-sm leading-snug">Best for international investors</span>
        </div>
      </li>
      <li class="flex items-start">
        <span class="text-accent-500 mr-2 mt-0.5">•</span>
        <div>
          <span class="text-slate-100 font-bold block text-sm">tastytrade</span>
          <span class="text-slate-400 text-sm leading-snug">Best for options trading</span>
        </div>
      </li>
      <li class="flex items-start">
        <span class="text-accent-500 mr-2 mt-0.5">•</span>
        <div>
          <span class="text-slate-100 font-bold block text-sm">Wise</span>
          <span class="text-slate-400 text-sm leading-snug">Best for currency conversion</span>
        </div>
      </li>
      <li class="flex items-start">
        <span class="text-accent-500 mr-2 mt-0.5">•</span>
        <div>
          <span class="text-slate-100 font-bold block text-sm">Market Chameleon</span>
          <span class="text-slate-400 text-sm leading-snug">Free IV Rank data</span>
        </div>
      </li>
    </ul>
  </div>

  <!-- Newsletter Signup -->
  <div class="w-[300px] bg-accent-500 rounded-xl p-4 shadow-lg shadow-accent-500/20">
    <h3 class="text-black font-bold text-lg leading-tight">Weekly Investment Insights</h3>
    <p class="text-slate-800 text-sm mt-1 mb-4">Join 5,000+ international investors</p>
    <form action="https://formsubmit.co/eladreck@gmail.com" method="POST" class="flex flex-col gap-2">
      <input type="hidden" name="_subject" value="New Website Subscriber!">
      <input type="email" name="email" placeholder="Your email address" class="w-full bg-white text-black placeholder-slate-500 px-3 py-2 border-none rounded-lg focus:ring-2 focus:ring-primary-900 focus:outline-none text-sm" required />
      <button type="submit" class="w-full bg-primary-900 text-slate-100 font-bold py-2 rounded-lg hover:bg-primary-600 transition-colors border-2 border-transparent">Subscribe</button>
    </form>
    <p class="text-slate-800 text-[11px] text-center mt-3 font-medium">No spam. Unsubscribe anytime.</p>
  </div>

  <!-- AdSense Bottom -->
  <div class="w-[300px] h-[250px] bg-primary-600 border-2 border-dashed border-slate-400 flex items-center justify-center text-slate-100 rounded-xl relative overflow-hidden">
    Advertisement
  </div>
</aside>
