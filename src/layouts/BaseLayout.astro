---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  theme?: 'dark' | 'light';
  keywords?: string[];
  seo?: {
    metaTitle?: string;
    metaDescription?: string;
    keywords?: string[];
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    twitterCard?: string;
  };
}

const { title, description, image, type, keywords, seo } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <SEOHead title={title} description={description} image={image} type={type} keywords={keywords} seo={seo} />
  <!-- Prevent flash: apply saved theme BEFORE paint -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.classList.add(t);
    })();
  </script>
  <body class="dark">
    <Header />
    <main class="flex-grow w-full">
      <slot />
    </main>
    <Footer />
    <AccessibilityWidget />
  </body>
</html>
