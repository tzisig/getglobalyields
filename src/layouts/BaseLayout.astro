---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  theme?: 'dark' | 'light';
  keywords?: string[];
  pubDate?: string;
  updatedDate?: string;
  author?: string;
  faq?: { question: string; answer: string }[];
  seo?: {
    metaTitle?: string;
    metaDescription?: string;
    keywords?: string[];
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    twitterCard?: string;
  };
}

const { title, description, image, type, keywords, seo, pubDate, updatedDate, author, faq } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <SEOHead title={title} description={description} image={image} type={type} keywords={keywords} seo={seo} pubDate={pubDate} updatedDate={updatedDate} author={author} faq={faq} />
  <!-- Prevent flash: apply saved theme BEFORE paint -->
  <script is:inline>
    (function() {
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.className = t;
    })();
  </script>
  
  <!-- Defer Google Analytics: set up dataLayer immediately, load gtag.js after idle -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-358H9G2F4C', { send_page_view: false });
    window.addEventListener('load', function() {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(function() {
          var s = document.createElement('script');
          s.async = true; s.src = 'https://www.googletagmanager.com/gtag/js?id=G-358H9G2F4C';
          document.head.appendChild(s);
          gtag('config', 'G-358H9G2F4C', { send_page_view: true });
        });
      } else {
        var s = document.createElement('script');
        s.async = true; s.src = 'https://www.googletagmanager.com/gtag/js?id=G-358H9G2F4C';
        document.head.appendChild(s);
        gtag('config', 'G-358H9G2F4C', { send_page_view: true });
      }
    });
  </script>
  <body>
    <script is:inline>document.body.className=localStorage.getItem('theme')||'dark'</script>
    
    <Header />
    <main class="flex-grow w-full">
      <slot />
    </main>
    <Footer />
    <AccessibilityWidget />
  </body>
</html>