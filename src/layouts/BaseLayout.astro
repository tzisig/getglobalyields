---
import SEOHead from '../components/SEOHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AccessibilityWidget from '../components/AccessibilityWidget.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  theme?: 'dark' | 'light';
  keywords?: string[];
  seo?: {
    metaTitle?: string;
    metaDescription?: string;
    keywords?: string[];
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    twitterCard?: string;
  };
}

const { title, description, image, type, keywords, seo } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <SEOHead title={title} description={description} image={image} type={type} keywords={keywords} seo={seo} />

  <!-- Google Analytics GA4 - loaded after page to avoid render-blocking -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-358H9G2F4C');
    window.addEventListener('load', function() {
      function loadGtag() {
        var s = document.createElement('script');
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-358H9G2F4C';
        s.async = true;
        document.head.appendChild(s);
      }
      if ('requestIdleCallback' in window) {
        requestIdleCallback(loadGtag);
      } else {
        setTimeout(loadGtag, 2000);
      }
    });
  </script>
  <!-- Prevent flash: apply saved theme BEFORE paint -->
  <script is:inline>
  (function() {
    var t = localStorage.getItem('theme') || 'dark';
    document.documentElement.className = t;
  })();
</script>
  <body>
   
    <!-- <Header /> -->

    <main class="flex-grow w-full">
  <div style="height: 1000px"></div>
</main>
    <Footer />
    <AccessibilityWidget />
  </body>
</html>
