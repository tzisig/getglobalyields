---
// AccessibilityWidget.astro
// Accessibility button - compliant with Israeli Equal Rights for Persons with Disabilities Law
---

<div id="accessibility-widget" aria-label="Accessibility menu">
  <button
    id="accessibility-toggle"
    aria-label="Open accessibility menu"
    aria-expanded="false"
    aria-controls="accessibility-panel"
    title="Accessibility"
  >
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="22" height="22" aria-hidden="true">
      <circle cx="12" cy="4.5" r="1.5"/>
      <path d="M8 9h8"/>
      <path d="M10 9v5l-2 4"/>
      <path d="M14 9v5l2 4"/>
      <path d="M7 20a5 5 0 0 0 10 0"/>
    </svg>
  </button>

  <div
    id="accessibility-panel"
    role="dialog"
    aria-label="Accessibility options"
    aria-modal="false"
    hidden
  >
    <div class="acc-header">
      <h2>Accessibility Settings</h2>
      <button id="accessibility-close" aria-label="Close accessibility menu">✕</button>
    </div>

    <div class="acc-body">
      <div class="acc-section">
        <h3>Text Size</h3>
        <div class="acc-row">
          <button class="acc-btn" data-action="font-decrease" aria-label="Decrease text size">A−</button>
          <button class="acc-btn" data-action="font-reset" aria-label="Reset text size">A</button>
          <button class="acc-btn" data-action="font-increase" aria-label="Increase text size">A+</button>
        </div>
      </div>

      <div class="acc-section">
        <h3>Contrast</h3>
        <div class="acc-row">
          <button class="acc-btn" data-action="contrast-high" aria-label="High contrast">High Contrast</button>
          <button class="acc-btn" data-action="contrast-reset" aria-label="Normal contrast">Normal</button>
        </div>
      </div>

      <div class="acc-section">
        <h3>Colors</h3>
        <div class="acc-row">
          <button class="acc-btn" data-action="grayscale-on" aria-label="Grayscale mode">Grayscale</button>
          <button class="acc-btn" data-action="grayscale-off" aria-label="Normal colors">Normal</button>
        </div>
      </div>

      <div class="acc-section">
        <h3>Links</h3>
        <div class="acc-row">
          <button class="acc-btn" data-action="links-highlight" aria-label="Highlight links">Highlight Links</button>
          <button class="acc-btn" data-action="links-reset" aria-label="Normal links">Normal</button>
        </div>
      </div>

      <div class="acc-section">
        <h3>Readable Font</h3>
        <div class="acc-row">
          <button class="acc-btn" data-action="font-readable" aria-label="Readable font">Readable Font</button>
          <button class="acc-btn" data-action="font-default" aria-label="Default font">Default</button>
        </div>
      </div>

      <div class="acc-section">
        <h3>Animations</h3>
        <div class="acc-row">
          <button class="acc-btn" data-action="animations-stop" aria-label="Stop animations">Stop Animations</button>
          <button class="acc-btn" data-action="animations-reset" aria-label="Enable animations">Enable</button>
        </div>
      </div>

      <button class="acc-btn acc-btn-reset" data-action="reset-all" aria-label="Reset all accessibility settings">
        Reset All Settings
      </button>

      <a href="/accessibility-statement" class="acc-statement-link">
        Accessibility Statement
      </a>
    </div>
  </div>
</div>

<style>
  #accessibility-widget {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 9999;
    font-family: 'Inter', system-ui, sans-serif;
  }

  @media (max-width: 768px) {
    #accessibility-widget {
      bottom: 16px;
      top: auto;
      left: auto;
      right: 16px;
    }
    #accessibility-panel {
      bottom: 54px;
      top: auto;
      left: auto;
      right: 0;
    }
  }

  #accessibility-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: var(--bg-elevated, #233554);
    color: var(--color-accent-500, #E0C870);
    border: 1px solid var(--border, #233554);
    border-radius: 8px;
    cursor: pointer;
    transition: background-color 0.2s, border-color 0.2s;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }

  #accessibility-toggle:hover {
    background-color: var(--color-accent-500, #E0C870);
    color: var(--color-primary-900, #0a192f);
    border-color: var(--color-accent-500, #E0C870);
  }

  #accessibility-toggle:focus-visible {
    outline: 2px solid var(--color-accent-500, #E0C870);
    outline-offset: 2px;
  }

  #accessibility-panel {
    position: absolute;
    bottom: 54px;
    left: 0;
    width: 272px;
    background: var(--bg-surface, #112240);
    border: 1px solid var(--border, #233554);
    border-radius: 10px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
    color: var(--text-body, #cbd5e1);
    overflow: hidden;
  }

  #accessibility-panel[hidden] { display: none; }

  .acc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px 14px;
    background: var(--bg-elevated, #233554);
    border-bottom: 1px solid var(--border, #233554);
  }

  .acc-header h2 {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent-500, #E0C870);
  }

  #accessibility-close {
    background: none;
    border: none;
    color: var(--text-muted, #94a3b8);
    cursor: pointer;
    font-size: 16px;
    padding: 2px 6px;
    border-radius: 4px;
    line-height: 1;
  }

  #accessibility-close:hover {
    color: var(--text-heading, #f1f5f9);
    background: var(--border, #233554);
  }

  #accessibility-close:focus-visible {
    outline: 2px solid var(--color-accent-500, #E0C870);
  }

  .acc-body {
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 65vh;
    overflow-y: auto;
  }

  .acc-section h3 {
    margin: 0 0 5px 0;
    font-size: 10px;
    color: var(--text-faint, #64748b);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .acc-row {
    display: flex;
    gap: 5px;
    flex-wrap: wrap;
  }

  .acc-btn {
    background: var(--bg-elevated, #233554);
    color: var(--text-body, #cbd5e1);
    border: 1px solid var(--border, #3a506b);
    border-radius: 6px;
    padding: 6px 10px;
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    flex: 1;
  }

  .acc-btn:hover {
    background: var(--border, #3a506b);
    color: var(--text-heading, #f1f5f9);
  }

  .acc-btn:focus-visible {
    outline: 2px solid var(--color-accent-500, #E0C870);
    outline-offset: 1px;
  }

  .acc-btn.active {
    background: color-mix(in srgb, var(--color-accent-500, #E0C870) 15%, transparent);
    border-color: var(--color-accent-500, #E0C870);
    color: var(--color-accent-400, #dcb963);
  }

  .acc-btn-reset {
    width: 100%;
    background: transparent;
    border-color: var(--border, #3a506b);
    color: var(--text-muted, #94a3b8);
    text-align: center;
    padding: 7px;
    margin-top: 2px;
    font-size: 12px;
  }

  .acc-btn-reset:hover {
    background: var(--bg-elevated, #233554);
    color: var(--text-heading, #f1f5f9);
  }

  .acc-statement-link {
    display: block;
    text-align: center;
    color: var(--color-accent-600, #aa8c3e);
    font-size: 12px;
    text-decoration: underline;
    padding: 2px 0;
  }

  .acc-statement-link:hover {
    color: var(--color-accent-500, #E0C870);
  }

  :root.acc-font-lg  { font-size: 110% !important; }
  :root.acc-font-xl  { font-size: 125% !important; }
  :root.acc-font-xxl { font-size: 145% !important; }
  :root.acc-high-contrast { filter: contrast(150%); }
  :root.acc-grayscale { filter: grayscale(100%); }
  :root.acc-high-contrast.acc-grayscale { filter: contrast(150%) grayscale(100%); }
  :root.acc-highlight-links a {
    text-decoration: underline !important;
    outline: 2px solid var(--color-accent-500, #E0C870) !important;
    outline-offset: 2px !important;
  }
  :root.acc-readable-font,
  :root.acc-readable-font * {
    font-family: Arial, Helvetica, sans-serif !important;
    letter-spacing: 0.03em !important;
    line-height: 1.6 !important;
  }
  :root.acc-no-animations *,
  :root.acc-no-animations *::before,
  :root.acc-no-animations *::after {
    animation: none !important;
    transition: none !important;
  }
</style>

<script>
  (function () {
    const toggle = document.getElementById('accessibility-toggle');
    const panel  = document.getElementById('accessibility-panel');
    const closeBtn = document.getElementById('accessibility-close');
    const root = document.documentElement;
    const FONT_CLASSES = ['acc-font-lg', 'acc-font-xl', 'acc-font-xxl'];
    let fontLevel = 0;

    function save(k, v) { try { localStorage.setItem('acc_' + k, v); } catch(e) {} }
    function load(k)    { try { return localStorage.getItem('acc_' + k); } catch(e) { return null; } }

    function updateFontClasses() {
      root.classList.remove(...FONT_CLASSES);
      if (fontLevel === 1) root.classList.add('acc-font-lg');
      if (fontLevel === 2) root.classList.add('acc-font-xl');
      if (fontLevel === 3) root.classList.add('acc-font-xxl');
    }

    function applyAllSaved() {
      fontLevel = parseInt(load('fontLevel') || '0');
      updateFontClasses();
      if (load('highContrast')   === '1') root.classList.add('acc-high-contrast');
      if (load('grayscale')      === '1') root.classList.add('acc-grayscale');
      if (load('linksHighlight') === '1') root.classList.add('acc-highlight-links');
      if (load('readableFont')   === '1') root.classList.add('acc-readable-font');
      if (load('noAnimations')   === '1') root.classList.add('acc-no-animations');
    }

    function openPanel() {
      panel.hidden = false;
      toggle.setAttribute('aria-expanded', 'true');
      closeBtn.focus();
    }

    function closePanel() {
      panel.hidden = true;
      toggle.setAttribute('aria-expanded', 'false');
      toggle.focus();
    }

    toggle.addEventListener('click', () => panel.hidden ? openPanel() : closePanel());
    closeBtn.addEventListener('click', closePanel);
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && !panel.hidden) closePanel(); });
    document.addEventListener('click', e => {
      if (!document.getElementById('accessibility-widget').contains(e.target) && !panel.hidden) closePanel();
    });

    panel.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-action]');
      if (!btn) return;
      switch (btn.dataset.action) {
        case 'font-increase': fontLevel = Math.min(fontLevel + 1, 3); updateFontClasses(); save('fontLevel', fontLevel); break;
        case 'font-decrease': fontLevel = Math.max(fontLevel - 1, 0); updateFontClasses(); save('fontLevel', fontLevel); break;
        case 'font-reset':    fontLevel = 0; updateFontClasses(); save('fontLevel', 0); break;
        case 'contrast-high':  root.classList.add('acc-high-contrast');    save('highContrast', '1'); break;
        case 'contrast-reset': root.classList.remove('acc-high-contrast'); save('highContrast', '0'); break;
        case 'grayscale-on':   root.classList.add('acc-grayscale');        save('grayscale', '1'); break;
        case 'grayscale-off':  root.classList.remove('acc-grayscale');     save('grayscale', '0'); break;
        case 'links-highlight': root.classList.add('acc-highlight-links');    save('linksHighlight', '1'); break;
        case 'links-reset':     root.classList.remove('acc-highlight-links'); save('linksHighlight', '0'); break;
        case 'font-readable': root.classList.add('acc-readable-font');    save('readableFont', '1'); break;
        case 'font-default':  root.classList.remove('acc-readable-font'); save('readableFont', '0'); break;
        case 'animations-stop':  root.classList.add('acc-no-animations');    save('noAnimations', '1'); break;
        case 'animations-reset': root.classList.remove('acc-no-animations'); save('noAnimations', '0'); break;
        case 'reset-all':
          fontLevel = 0; updateFontClasses();
          root.classList.remove('acc-high-contrast','acc-grayscale','acc-highlight-links','acc-readable-font','acc-no-animations');
          ['fontLevel','highContrast','grayscale','linksHighlight','readableFont','noAnimations'].forEach(k => save(k, '0'));
          break;
      }
    });

    applyAllSaved();
  })();
</script>

