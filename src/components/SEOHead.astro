---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  keywords?: string[];
  pubDate?: string;
  updatedDate?: string;
  author?: string;
  faq?: { question: string; answer: string }[];
  seo?: {
    metaTitle?: string;
    metaDescription?: string;
    keywords?: string[];
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    twitterCard?: string;
  };
}

const {
  title = "Get Global Yields - Finance & Investment Insights",
  description = "Expert reviews, how-to guides, and comparisons for global financial products, high-yield accounts, and investment strategies.",
  image = "/og-image.jpg",
  type = "website",
  keywords = [],
  pubDate,
  updatedDate,
  author,
  faq = [],
  seo = {}
} = Astro.props;

const finalTitle       = seo?.metaTitle       || title;
const finalDescription = seo?.metaDescription || description;
const finalImage       = seo?.ogImage         || image;
const finalOgTitle     = seo?.ogTitle         || finalTitle;
const finalOgDesc      = seo?.ogDescription   || finalDescription;
const finalKeywords    = seo?.keywords?.length ? seo.keywords : keywords;
const twitterCard      = seo?.twitterCard     || "summary_large_image";

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url);
const ogImageUrl   = new URL(finalImage, Astro.site || Astro.url);

const articleSchema = type === "article" ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": finalTitle,
  "description": finalDescription,
  "image": ogImageUrl.toString(),
  "datePublished": pubDate,
  "dateModified": updatedDate || pubDate,
  "author": { "@type": "Organization", "name": author || "Get Global Yields" },
  "publisher": {
    "@type": "Organization",
    "name": "Get Global Yields",
    "url": "https://getglobalyields.com"
  }
} : null;

const faqSchema = faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
} : null;
---

<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon.webp?v=3" />
  <meta name="generator" content={Astro.generator} />

  <link rel="canonical" href={canonicalURL} />

  <title>{finalTitle}</title>
  <meta name="title" content={finalTitle} />
  <meta name="description" content={finalDescription} />
  {finalKeywords.length > 0 && (
    <meta name="keywords" content={finalKeywords.join(", ")} />
  )}

  <meta property="og:type" content={type} />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content={finalOgTitle} />
  <meta property="og:description" content={finalOgDesc} />
  <meta property="og:image" content={ogImageUrl} />

  <meta property="twitter:card" content={twitterCard} />
  <meta property="twitter:url" content={Astro.url} />
  <meta property="twitter:title" content={finalOgTitle} />
  <meta property="twitter:description" content={finalOgDesc} />
  <meta property="twitter:image" content={ogImageUrl} />

  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="alternate" type="application/rss+xml" title="Get Global Yields - RSS" href="/rss.xml" />

  <meta name='impact-site-verification' value='583bc75e-04c9-4042-a2dc-cdfce51ea9c6'>
  <meta name='impact-site-verification' value='11671c53-055e-4f0b-a0d1-8d3b07033f6d'>

  {articleSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  )}
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}
  <meta name="p:domain_verify" content="55e6f8ad1a23e33deb0edc8cc395f68a"/>
</head>