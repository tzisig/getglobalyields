---
export interface Props {
  darkSrc: string;
  lightSrc: string;
  alt: string;
  width: number;
  height: number;
  class?: string;
  loading?: 'eager' | 'lazy';
  fetchpriority?: 'high' | 'low' | 'auto' | null;
  decoding?: 'sync' | 'async' | 'auto';
}

const {
  darkSrc,
  lightSrc,
  alt,
  width,
  height,
  class: className = '',
  loading = 'eager',
  fetchpriority = 'high',
  decoding,
} = Astro.props;
---

<span
  data-theme-hero-slot
  data-dark-src={darkSrc}
  data-light-src={lightSrc}
  data-alt={alt}
  data-width={width}
  data-height={height}
  data-class={className}
  data-loading={loading}
  data-fetchpriority={fetchpriority ?? undefined}
  data-decoding={decoding}
  class={className}
  style={`display: block; aspect-ratio: ${width} / ${height};`}
></span>
<script is:inline>
  (function () {
    var script = document.currentScript;
    var slot = script && script.previousElementSibling;
    if (!(slot instanceof HTMLElement) || !slot.hasAttribute('data-theme-hero-slot')) return;

    var image = document.createElement('img');
    image.alt = slot.dataset.alt || '';
    image.width = Number(slot.dataset.width);
    image.height = Number(slot.dataset.height);
    image.className = slot.dataset.class || '';
    image.loading = slot.dataset.loading || 'eager';
    if (slot.dataset.fetchpriority) image.fetchPriority = slot.dataset.fetchpriority;
    if (slot.dataset.decoding) image.decoding = slot.dataset.decoding;

    slot.replaceWith(image);

    var coordinator = window.__ggyThemeHeroCoordinator;
    if (!coordinator) {
      var registrations = new Set();

      function updateRegistration(registration) {
        var source = document.documentElement.classList.contains('light')
          ? registration.lightSrc
          : registration.darkSrc;
        if (source && registration.image.getAttribute('src') !== source) {
          registration.image.src = source;
        }
      }

      function updateAll() {
        registrations.forEach(function (registration) {
          if (!registration.image.isConnected) {
            registrations.delete(registration);
            return;
          }
          updateRegistration(registration);
        });
      }

      var observer = new MutationObserver(updateAll);
      observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['class'],
      });

      coordinator = {
        observer: observer,
        registrations: registrations,
        register: function (registration) {
          registrations.add(registration);
          updateRegistration(registration);
        },
        destroy: function () {
          observer.disconnect();
          registrations.clear();
          if (window.__ggyThemeHeroCoordinator === coordinator) {
            delete window.__ggyThemeHeroCoordinator;
          }
        },
      };

      window.__ggyThemeHeroCoordinator = coordinator;
      document.addEventListener('astro:before-swap', coordinator.destroy, { once: true });
    }

    coordinator.register({
      image: image,
      darkSrc: slot.dataset.darkSrc,
      lightSrc: slot.dataset.lightSrc,
    });
  })();
</script>
<noscript>
  <style>[data-theme-hero-slot] { display: none !important; }</style>
  <img
    src={darkSrc}
    alt={alt}
    width={width}
    height={height}
    class={className}
    loading={loading}
    fetchpriority={fetchpriority ?? undefined}
    decoding={decoding}
  />
</noscript>
