---
export interface Props {
  title: string;
  description: string;
  href: string;
  date: Date;
  categoryName?: string;
  image?: string;
  imageLight?: string;
  imageDark?: string;
  isFeatured?: boolean;
}

const { title, description, href, date, categoryName, image, imageLight, imageDark, isFeatured = false } = Astro.props;
const hasThemeImages = Boolean(imageLight || imageDark);
const lightImage = imageLight ?? image;
const darkImage = imageDark ?? image;
---

<a href={href} class={`group block h-full ${isFeatured ? 'md:col-span-2 lg:col-span-3' : ''}`}>
  <article class={`flex flex-col h-full bg-primary-800 rounded-xl overflow-hidden transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 ${isFeatured ? 'border border-accent-500/30 hover:border-accent-400 shadow-xl shadow-accent-500/5' : 'border border-primary-700 hover:border-accent-500 hover:shadow-accent-500/10'}`}>
    
    <div class={`relative overflow-hidden flex items-center justify-center bg-primary-800 ${isFeatured ? 'w-full' : 'h-48'}`}>
      {hasThemeImages || image ? (
        <>
          {lightImage && (
            <img src={lightImage} alt={title} class={`w-full transition-transform duration-700 group-hover:scale-105 theme-light-only ${isFeatured ? 'h-auto block' : 'h-full object-cover'}`} />
          )}
          {darkImage && (
            <img src={darkImage} alt={title} class={`w-full transition-transform duration-700 group-hover:scale-105 theme-dark-only ${isFeatured ? 'h-auto block' : 'h-full object-cover'}`} />
          )}
        </>
      ) : (
        <div class="w-full h-full flex items-center justify-center text-primary-600 bg-primary-900 border-b border-primary-700">
          <svg class="w-12 h-12 opacity-50" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14" />
          </svg>
        </div>
      )}
      {!isFeatured && categoryName && (
        <span class="absolute top-4 left-4 bg-accent-500 text-primary-900 text-xs font-bold px-2 py-1 rounded uppercase tracking-wider shadow-sm z-10">
          {categoryName}
        </span>
      )}
    </div>

    <div class={`flex flex-col flex-grow ${isFeatured ? 'p-8 md:p-12 lg:p-16' : 'p-6'}`}>
      
      {isFeatured && (
        <div class="flex flex-wrap items-center gap-3 mb-6">
          {categoryName && (
            <span class="bg-accent-500 text-primary-900 text-sm font-bold px-4 py-1.5 rounded uppercase tracking-wider shadow-sm">
              {categoryName}
            </span>
          )}
          <span class="bg-primary-900 text-accent-500 border border-accent-500/50 text-sm font-extrabold px-4 py-1.5 rounded-full uppercase tracking-widest shadow-sm flex items-center gap-1.5">
            <svg class="w-4 h-4 text-accent-400" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            Featured
          </span>
        </div>
      )}

      <time class={`font-mono mb-3 ${isFeatured ? 'text-sm text-slate-300' : 'text-xs text-slate-400'}`} datetime={date.toISOString()}>
        {date.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}
      </time>
      
      <h3 class={`text-slate-100 group-hover:text-accent-500 line-clamp-2 transition-colors duration-200 ${isFeatured ? 'text-3xl md:text-5xl lg:text-6xl font-black mb-6 leading-tight tracking-tight' : 'text-xl font-bold mb-3'}`}>
        {title}
      </h3>
      
      <p class={`text-slate-400 line-clamp-3 mb-8 flex-grow ${isFeatured ? 'text-lg md:text-xl leading-relaxed max-w-4xl' : 'text-sm mb-6'}`}>
        {description}
      </p>
      
      <div class={`capitalize flex items-center text-accent-500 font-bold mt-auto ${isFeatured ? 'text-lg tracking-wide' : 'text-sm'}`}>
        Read Article
        <svg class={`ml-1.5 transition-transform duration-300 group-hover:translate-x-2 ${isFeatured ? 'w-5 h-5' : 'w-4 h-4'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </div>
    </div>
  </article>
</a>
