  }

  function getCookieLang() {
    var m = document.cookie.match(/googtrans=\/en\/([^;]+)/);
    return m ? m[1] : null;
  }

  function applyRTL(lang) {
    document.documentElement.setAttribute('dir', RTL_LANGS.indexOf(lang) !== -1 ? 'rtl' : 'ltr');
  }

  function triggerSelect(lang, attempts) {
    attempts = attempts || 0;
    var select = document.querySelector('.goog-te-combo');
    if (select) {
      select.value = lang;
      select.dispatchEvent(new Event('change', { bubbles: true }));
      select.dispatchEvent(new Event('input',  { bubbles: true }));
      return;
    }
    if (attempts < 25) {
      setTimeout(function () { triggerSelect(lang, attempts + 1); }, 200);
    } else {
      setCookie(lang);
      location.reload();
    }
  }

  function loadGoogleTranslate(callback) {
    if (window.google && window.google.translate) {
      callback && callback();
      return;
    }
    window.googleTranslateElementInit = function () {
      new window.google.translate.TranslateElement(
        { pageLanguage: 'en', autoDisplay: false },
        'google_translate_element'
      );
      callback && callback();
    };
    var s = document.createElement('script');
    s.src = '//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit';
    s.async = true;
    document.head.appendChild(s);
  }

  function doTranslate(lang) {
    setCookie(lang);
    applyRTL(lang);
    loadGoogleTranslate(function() {
      triggerSelect(lang);
    });
  }

  function doReset() {
    clearCookie();
    document.documentElement.setAttribute('dir', 'ltr');
    location.reload();
  }

  function buildDropdown(ddEl, resetId, flagId) {
    // dropdown is now static HTML - nothing to build
  }

  function closeAll() {
    ['translate-dropdown-desktop', 'translate-dropdown-mobile'].forEach(function (id) {
      var el = document.getElementById(id);
      if (el) { el.hidden = true; }
    });
    ['translate-btn-desktop', 'translate-btn-mobile'].forEach(function (id) {
      var el = document.getElementById(id);
      if (el) { el.setAttribute('aria-expanded', 'false'); }
    });
  }

  function setupTranslate() {
    var ddDesktop = document.getElementById('translate-dropdown-desktop');
    var ddMobile  = document.getElementById('translate-dropdown-mobile');
    var btnDesktop = document.getElementById('translate-btn-desktop');
    var btnMobile  = document.getElementById('translate-btn-mobile');

    if (!ddDesktop || !btnDesktop) return;

    // Build dropdowns once
    if (!ddDesktop.dataset.built) {
      buildDropdown(ddDesktop, 'lang-reset-desktop', 'translate-flag-desktop');
      ddDesktop.dataset.built = '1';

      // Attach click handlers to static buttons
      ddDesktop.querySelectorAll('.lang-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var lang = btn.getAttribute('data-lang');
          var cc = btn.getAttribute('data-cc');
          var label = btn.querySelector('span') ? btn.querySelector('span').textContent : lang;
          var flagImg = '<img src="https://flagcdn.com/40x30/' + cc + '.png" width="20" height="15" alt="' + label + '" />';
          doTranslate(lang);
          document.querySelectorAll('.lang-btn').forEach(function (b) { b.classList.remove('selected'); });
          document.querySelectorAll('[id^="translate-flag"]').forEach(function (el) { el.innerHTML = flagImg; });
          document.querySelectorAll('[class="lang-btn"][data-lang="' + lang + '"]').forEach(function (b) { b.classList.add('selected'); });
          document.querySelectorAll('.lang-reset').forEach(function (r) { r.style.display = 'block'; });
          closeAll();
        });
      });
      document.getElementById('lang-reset-desktop').addEventListener('click', doReset);
    }

    if (ddMobile && !ddMobile.dataset.built) {
      buildDropdown(ddMobile, 'lang-reset-mobile', 'translate-flag-mobile');
      ddMobile.dataset.built = '1';

      ddMobile.querySelectorAll('.lang-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var lang = btn.getAttribute('data-lang');
          var cc = btn.getAttribute('data-cc');
          var label = btn.querySelector('span') ? btn.querySelector('span').textContent : lang;
          var flagImg = '<img src="https://flagcdn.com/40x30/' + cc + '.png" width="20" height="15" alt="' + label + '" />';
          doTranslate(lang);
          document.querySelectorAll('.lang-btn').forEach(function (b) { b.classList.remove('selected'); });
          document.querySelectorAll('[id^="translate-flag"]').forEach(function (el) { el.innerHTML = flagImg; });
          document.querySelectorAll('.lang-reset').forEach(function (r) { r.style.display = 'block'; });
          closeAll();
        });
      });
      document.getElementById('lang-reset-mobile').addEventListener('click', doReset);
    }

    function toggle(dd, btn) {
      var isHidden = dd.hidden;
      closeAll();
      if (isHidden) {
        dd.hidden = false;
        btn.setAttribute('aria-expanded', 'true');
      }
    }

    btnDesktop.addEventListener('click', function (e) {
      e.stopPropagation();
      toggle(ddDesktop, btnDesktop);
    });

    if (btnMobile && ddMobile) {
      btnMobile.addEventListener('click', function (e) {
        e.stopPropagation();
        toggle(ddMobile, btnMobile);
      });
    }

    document.addEventListener('click', closeAll);
    [ddDesktop, ddMobile].forEach(function (dd) {
      if (dd) dd.addEventListener('click', function (e) { e.stopPropagation(); });
    });
    document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeAll(); });

    // Restore saved state
    var saved = getCookieLang();
    if (saved) {
      applyRTL(saved);
      var match = LANGS.find(function (l) { return l.lang === saved; });
      if (match) {
        var cc = flag_map[saved] || saved;
        var flagImg = '<img src="https://flagcdn.com/40x30/' + cc + '.png" width="20" height="15" alt="' + match.label + '" />';
        document.querySelectorAll('[id^="translate-flag"]').forEach(function (el) { el.innerHTML = flagImg; });
        document.querySelectorAll('.lang-reset').forEach(function (r) { r.style.display = 'block'; });
        // Load translate engine since a language was previously selected
        loadGoogleTranslate(function() { triggerSelect(saved); });
      }
    }
  }

  setupTranslate();
  document.addEventListener('astro:page-load', setupTranslate);
})();
</script>

