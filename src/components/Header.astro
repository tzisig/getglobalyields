---
const navItems = [
  { name: 'Start Here', href: '/start-here' },
  { name: 'Best Brokers', href: '/best-brokers',highlight: true },
  { name: 'US Investing', href: '/us-investing' },
  { name: 'Options Income', href: '/options-income' },
  { name: 'Taxes', href: '/taxes' },
  { name: 'Strategies', href: '/strategies' },
  { name: 'Case study', href: '/case-study/from-minus-70-to-plus-492k-real-tqqq-recovery-case-study' },
  { 
    name: 'Tools', 
    dropdown: true, 
    items: [
      { name: 'Investment Calculators', href: '/resources/calculators' },
      { name: 'Broker Finder', href: '/broker-finder' },
      { name: 'Broker Cost Calculator', href: '/broker-calculator' },
      { name: 'Tax Map', href: '/tax-map' },
      { name: 'Investor Profiles', href: '/investor-profiles' },
      { name: 'Weekly Update', href: '/weekly-update' },
      { name: 'Glossary', href: '/resources/glossary' },
      { name: 'Useful Links', href: '/resources/useful-links' },
    ]
  },
];

const currentPath = Astro.url.pathname;
