<script>
  // ─── Theme Toggle ────────────────────────────────────────
  function applyTheme(theme: string) {
    // Apply to both body and html (html class set by inline script in BaseLayout)
    document.body.classList.remove('light', 'dark');
    document.body.classList.add(theme);
    document.documentElement.classList.remove('light', 'dark');
    document.documentElement.classList.add(theme);
    localStorage.setItem('theme', theme);

    const isDark = theme === 'dark';
    // Sun = shown in dark mode (click to go light)
    // Moon = shown in light mode (click to go dark)
    document.getElementById('icon-sun')?.classList.toggle('hidden', !isDark);
    document.getElementById('icon-moon')?.classList.toggle('hidden', isDark);
    document.getElementById('icon-sun-mobile')?.classList.toggle('hidden', !isDark);
    document.getElementById('icon-moon-mobile')?.classList.toggle('hidden', isDark);
  }

  function setupTheme() {
    const saved = localStorage.getItem('theme') || 'dark';
    applyTheme(saved);

    const handleToggle = () => {
      const next = document.body.classList.contains('dark') ? 'light' : 'dark';
      applyTheme(next);
    };

    // Always clone to remove stale listeners before re-attaching
    ['theme-toggle', 'theme-toggle-mobile'].forEach((id) => {
      const el = document.getElementById(id);
      if (!el) return;
      const clone = el.cloneNode(true) as HTMLElement;
      el.parentNode?.replaceChild(clone, el);
      clone.addEventListener('click', handleToggle);
    });
  }

  setupTheme();
  document.addEventListener('astro:page-load', setupTheme);

  // ─── Mobile Menu ─────────────────────────────────────────
  function setupMobileMenu() {
    const button = document.getElementById('mobile-menu-button');
    const menu   = document.getElementById('mobile-menu');
    if (!button || !menu) return;

    const fresh = button.cloneNode(true) as HTMLButtonElement;
    button.parentNode?.replaceChild(fresh, button);

    fresh.addEventListener('click', () => {
      const expanded = fresh.getAttribute('aria-expanded') === 'true';
      fresh.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
      const svgs = fresh.querySelectorAll('svg');
      if (svgs.length >= 2) {
        svgs[0].classList.toggle('hidden');
        svgs[0].classList.toggle('block');
        svgs[1].classList.toggle('hidden');
        svgs[1].classList.toggle('block');
      }
    });
  }

  setupMobileMenu();
  document.addEventListener('astro:page-load', setupMobileMenu);
</script>

