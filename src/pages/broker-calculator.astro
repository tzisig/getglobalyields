---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="The Wrong Broker Cost Calculator � Get Global Yields">
  <section class="w-full px-4 pt-10 pb-14 sm:px-6 sm:pt-12 sm:pb-16 lg:px-8 lg:pt-14 lg:pb-20">
    <div class="broker-calculator-container">
      <div class="header">
        <div class="icon-circle">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
        </div>
        <h1>The <span>Wrong Broker</span> Cost Calculator</h1>
        <p>See how much hidden fees are really costing you � and what you could save by switching to a better broker.</p>
      </div>

      <div class="form-grid" id="form-grid">
        <div class="form-group">
          <label for="monthly-investment">Monthly Investment</label>
          <div class="input-wrapper">
            <span class="prefix">$</span>
            <input type="number" id="monthly-investment" class="has-prefix" placeholder="500" value="500" min="1" max="100000" step="1">
          </div>
        </div>
        <div class="form-group">
          <label for="years">Years of Investing</label>
          <div class="input-wrapper">
            <input type="number" id="years" placeholder="10" value="10" min="1" max="50" step="1">
            <span class="suffix">yrs</span>
          </div>
        </div>
        <div class="form-group">
          <label for="current-fee">Current Broker Fee</label>
          <div class="input-wrapper">
            <input type="number" id="current-fee" class="has-suffix" placeholder="1.5" value="1.5" min="0" max="10" step="0.01">
            <span class="suffix">%</span>
          </div>
        </div>
        <div class="form-group">
          <label for="better-fee">Better Broker Fee</label>
          <div class="input-wrapper">
            <input type="number" id="better-fee" class="has-suffix" placeholder="0.1" value="0.1" min="0" max="10" step="0.01">
            <span class="suffix">%</span>
          </div>
        </div>
      </div>

      <button class="btn-calculate" id="btn-calculate">Calculate Your Lost Savings</button>

      <div class="results-area" id="results-area">
        <div class="savings-banner" id="savings-banner">
          <div class="savings-amount" id="savings-amount">$0</div>
          <div class="savings-label" id="savings-label">you could save over this period</div>
        </div>

        <div class="stats-row">
          <div class="stat-card">
            <div class="stat-value danger" id="stat-lost">$0</div>
            <div class="stat-label">Total Lost to Fees (Current)</div>
          </div>
          <div class="stat-card">
            <div class="stat-value" id="stat-total-invested">$0</div>
            <div class="stat-label">Total Invested</div>
          </div>
          <div class="stat-card">
            <div class="stat-value success" id="stat-final-better">$0</div>
            <div class="stat-label">Final Balance (Better Broker)</div>
          </div>
        </div>

        <div class="chart-container">
          <canvas id="chart"></canvas>
        </div>
      </div>
    </div>

    <div class="disclaimer-wrapper">
      <div class="disclaimer">
        <strong>Disclaimer:</strong> This calculator provides estimates based on simple fee comparisons and does not account for market returns, currency fluctuations, or compounding. Actual results will vary. Always verify fees directly with brokers before making decisions.
      </div>
    </div>
  </section>

  <script is:inline src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script is:inline>
    (function() {
      const monthlyInput = document.getElementById('monthly-investment');
      const yearsInput = document.getElementById('years');
      const currentFeeInput = document.getElementById('current-fee');
      const betterFeeInput = document.getElementById('better-fee');
      const btnCalculate = document.getElementById('btn-calculate');
      const resultsArea = document.getElementById('results-area');
      const savingsAmount = document.getElementById('savings-amount');
      const savingsLabel = document.getElementById('savings-label');
      const statLost = document.getElementById('stat-lost');
      const statTotalInvested = document.getElementById('stat-total-invested');
      const statFinalBetter = document.getElementById('stat-final-better');
      const chartCanvas = document.getElementById('chart');

      let chartInstance = null;

      function formatCurrency(amount) {
        if (amount >= 1000000) return '$' + (amount / 1000000).toFixed(2) + 'M';
        if (amount >= 1000) {
          return '$' + amount.toLocaleString('en-US', {
            minimumFractionDigits: 0,
            maximumFractionDigits: 0,
          });
        }
        return '$' + amount.toLocaleString('en-US', {
          minimumFractionDigits: 2,
          maximumFractionDigits: 2,
        });
      }

      function calculate() {
        const monthly = parseFloat(monthlyInput.value) || 0;
        const years = parseInt(yearsInput.value, 10) || 1;
        const currentFeePct = parseFloat(currentFeeInput.value) || 0;
        const betterFeePct = parseFloat(betterFeeInput.value) || 0;

        if (monthly <= 0 || years <= 0) {
          resultsArea.classList.remove('active');
          return;
        }

        const totalMonths = years * 12;
        const totalInvested = monthly * totalMonths;
        const totalCurrentFees = totalInvested * (currentFeePct / 100);
        const totalBetterFees = totalInvested * (betterFeePct / 100);
        const totalSaved = totalCurrentFees - totalBetterFees;
        const finalBetter = totalInvested - totalBetterFees;

        const labels = [];
        const currentData = [];
        const betterData = [];
        const investedData = [];

        for (let y = 0; y <= years; y += 1) {
          labels.push('Year ' + y);
          const cumInvested = monthly * 12 * y;
          const cumCurrentFees = cumInvested * (currentFeePct / 100);
          const cumBetterFees = cumInvested * (betterFeePct / 100);
          investedData.push(cumInvested);
          currentData.push(cumInvested - cumCurrentFees);
          betterData.push(cumInvested - cumBetterFees);
        }

        savingsAmount.textContent = formatCurrency(totalSaved);
        savingsLabel.textContent = totalSaved > 0
          ? 'you could save over ' + years + ' years by switching'
          : 'no significant savings detected';
        statLost.textContent = formatCurrency(totalCurrentFees);
        statTotalInvested.textContent = formatCurrency(totalInvested);
        statFinalBetter.textContent = formatCurrency(finalBetter);
        resultsArea.classList.add('active');

        renderChart(labels, currentData, betterData, investedData);
      }

      function renderChart(labels, currentData, betterData, investedData) {
        if (chartInstance) {
          chartInstance.destroy();
          chartInstance = null;
        }

        const ctx = chartCanvas.getContext('2d');
        chartInstance = new Chart(ctx, {
          type: 'line',
          data: {
            labels: labels,
            datasets: [
              {
                label: 'Total Invested',
                data: investedData,
                borderColor: '#64748b',
                backgroundColor: 'transparent',
                borderWidth: 2,
                borderDash: [6, 4],
                pointRadius: 0,
                pointHoverRadius: 4,
                pointHoverBackgroundColor: '#64748b',
                order: 2,
                tension: 0.1,
              },
              {
                label: 'Balance � Better Broker',
                data: betterData,
                borderColor: '#22c55e',
                backgroundColor: 'rgba(34, 197, 94, 0.08)',
                borderWidth: 3,
                fill: true,
                pointRadius: 0,
                pointHoverRadius: 5,
                pointHoverBackgroundColor: '#22c55e',
                order: 1,
                tension: 0.2,
              },
              {
                label: 'Balance � Current Broker',
                data: currentData,
                borderColor: '#ef4444',
                backgroundColor: 'rgba(239, 68, 68, 0.06)',
                borderWidth: 3,
                fill: true,
                pointRadius: 0,
                pointHoverRadius: 5,
                pointHoverBackgroundColor: '#ef4444',
                order: 0,
                tension: 0.2,
              },
            ],
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            interaction: { mode: 'index', intersect: false },
            plugins: {
              legend: {
                position: 'bottom',
                labels: {
                  color: '#cbd5e1',
                  usePointStyle: true,
                  pointStyleWidth: 10,
                  padding: 24,
                  font: { size: 12, family: "'Segoe UI', system-ui, sans-serif" },
                },
              },
              tooltip: {
                backgroundColor: '#1e293b',
                titleColor: '#f1f5f9',
                bodyColor: '#cbd5e1',
                borderColor: '#334155',
                borderWidth: 1,
                padding: 12,
                cornerRadius: 8,
                displayColors: true,
              },
            },
            scales: {
              x: {
                ticks: { color: '#94a3b8', font: { size: 11 }, maxTicksLimit: 10 },
                grid: { color: 'rgba(51, 65, 85, 0.4)', drawBorder: false },
              },
              y: {
                ticks: {
                  color: '#94a3b8',
                  font: { size: 11 },
                  callback: function(value) {
                    if (value >= 1000000) return '$' + (value / 1000000).toFixed(1) + 'M';
                    if (value >= 1000) return '$' + (value / 1000).toFixed(0) + 'K';
                    return '$' + value;
                  },
                },
                grid: { color: 'rgba(51, 65, 85, 0.4)', drawBorder: false },
                beginAtZero: true,
              },
            },
          },
        });

        resultsArea.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      btnCalculate.addEventListener('click', calculate);
      [monthlyInput, yearsInput, currentFeeInput, betterFeeInput].forEach((input) => {
        input.addEventListener('keydown', function(e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            calculate();
          }
        });
      });

      calculate();
    })();
  </script>
</BaseLayout>

<style>
  :root {
    --bg-primary: #0f172a;
    --bg-secondary: #1e293b;
    --bg-card: #1a2332;
    --border: #334155;
    --text-primary: #f1f5f9;
    --text-secondary: #cbd5e1;
    --text-muted: #94a3b8;
    --accent: #D4B95A;
    --accent-hover: #d4b55a;
    --accent-bg: rgba(212, 185, 90, 0.1);
    --accent-border: rgba(212, 185, 90, 0.3);
    --red: #ef4444;
    --green: #22c55e;
    --blue-accent: #3b82f6;
    --danger-bg: rgba(239, 68, 68, 0.1);
    --success-bg: rgba(34, 197, 94, 0.1);
    --shadow-lg: 0 12px 40px -12px rgba(0, 0, 0, 0.6);
    --shadow-card: 0 4px 16px rgba(0, 0, 0, 0.3);
    --radius-lg: 20px;
    --radius-md: 12px;
    --radius-sm: 8px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  .broker-calculator-container {
    width: 100%;
    max-width: 900px;
    background: var(--bg-secondary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border);
    padding: 40px 36px;
    box-shadow: var(--shadow-lg);
    margin: 24px auto 0;
  }

  .disclaimer-wrapper {
    width: 100%;
    max-width: 900px;
    margin: 16px auto 24px;
  }

  .header {
    text-align: center;
    margin-bottom: 32px;
  }

  .header .icon-circle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--danger-bg);
    border: 2px solid rgba(239, 68, 68, 0.25);
    margin-bottom: 14px;
  }

  .header .icon-circle svg {
    width: 28px;
    height: 28px;
    color: var(--red);
  }

  .header h1 {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 4px;
    letter-spacing: -0.02em;
  }

  .header h1 span {
    color: var(--accent);
  }

  .header p {
    color: var(--text-muted);
    font-size: 0.95rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 28px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--text-secondary);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .form-group .input-wrapper {
    position: relative;
  }

  .form-group .input-wrapper .prefix {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.9rem;
    pointer-events: none;
  }

  .form-group .input-wrapper .suffix {
    position: absolute;
    right: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-muted);
    font-weight: 600;
    font-size: 0.85rem;
    pointer-events: none;
  }

  .form-group input {
    width: 100%;
    padding: 13px 16px;
    font-size: 1rem;
    font-family: inherit;
    background: var(--bg-primary);
    color: var(--text-primary);
    border: 2px solid var(--border);
    border-radius: var(--radius-sm);
    outline: none;
    transition: all 0.2s ease;
  }

  .form-group input.has-prefix {
    padding-left: 38px;
  }

  .form-group input.has-suffix {
    padding-right: 44px;
  }

  .form-group input:hover {
    border-color: #64748b;
  }

  .form-group input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 4px rgba(212, 185, 90, 0.12);
  }

  .btn-calculate {
    display: block;
    width: 100%;
    padding: 14px;
    font-size: 1.05rem;
    font-weight: 700;
    font-family: inherit;
    background: var(--accent);
    color: #0f172a;
    border: none;
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: 0.01em;
    margin-bottom: 24px;
  }

  .btn-calculate:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(212, 185, 90, 0.3);
  }

  .btn-calculate:active {
    transform: translateY(0);
  }

  .results-area {
    display: none;
    animation: fadeIn 0.4s ease;
  }

  .results-area.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .savings-banner {
    background: var(--success-bg);
    border: 1px solid rgba(34, 197, 94, 0.25);
    border-radius: var(--radius-md);
    padding: 18px 20px;
    text-align: center;
    margin-bottom: 24px;
  }

  .savings-banner .savings-amount {
    font-size: 2rem;
    font-weight: 800;
    color: var(--green);
    letter-spacing: -0.02em;
  }

  .savings-banner .savings-label {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-top: 2px;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-card {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px;
    text-align: center;
  }

  .stat-card .stat-value {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .stat-card .stat-value.danger {
    color: var(--red);
  }

  .stat-card .stat-value.success {
    color: var(--green);
  }

  .stat-card .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 4px;
  }

  .chart-container {
    background: var(--bg-primary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 20px;
    position: relative;
    height: 350px;
  }

  .chart-container canvas {
    width: 100% !important;
    height: 100% !important;
  }

  .disclaimer {
    padding: 14px 18px;
    background: var(--bg-primary);
    border-radius: var(--radius-sm);
    font-size: 0.78rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    line-height: 1.5;
    text-align: center;
  }

  @media (max-width: 768px) {
    .broker-calculator-container {
      padding: 24px 16px;
      border-radius: 14px;
    }

    .header h1 {
      font-size: 1.4rem;
    }

    .form-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .stats-row {
      grid-template-columns: 1fr 1fr;
    }

    .chart-container {
      height: 260px;
      padding: 12px;
    }

    .savings-banner .savings-amount {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 400px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
  }
</style>

