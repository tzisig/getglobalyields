---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('case-study'))
  .map(p => ({ ...p, type: 'case-studies', url: `/case-study/${p.data.slug ?? p.id}` }));
---

<BaseLayout
  title="Real Investment Case Studies"
  description="Real-world case studies detailing portfolio growth and yield generation using global brokers."
>
  <div class="bg-primary-900 py-16 lg:py-24 border-b border-primary-700 relative overflow-hidden">
    <div class="container relative mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-6 leading-tight">
        Transparency in Action:<br class="hidden md:block" /> <span class="text-accent-500">Real-Money Case Studies</span>
      </h1>
      <p class="text-xl text-slate-300 leading-relaxed max-w-3xl mx-auto">
        No theories, no 'what-ifs.' We peel back the curtain on live portfolios, showing exactly how global yield strategies perform in volatile markets.
      </p>
    </div>
  </div>

  <section class="py-16 min-h-screen">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.length > 0 ? posts.map(post => {
          const isFeatured = post.id.includes('tqqq-recovery');
          return (
            <Card
              title={post.data.title}
              description={post.data.description}
              href={post.url}
              date={post.data.pubDate}
              categoryName={post.type}
              image={post.data.heroImage}
              imageLight={post.data.heroImageLight}
              imageDark={post.data.heroImageDark}
              isFeatured={isFeatured}
            />
          );
        }) : (
           <div class="col-span-full text-center py-12 bg-primary-900 rounded-lg border border-primary-700 border-dashed">
             <p class="text-slate-400">Content coming soon!</p>
           </div>
        )}
      </div>
    </div>
  </section>
  <!-- Financial Disclaimer -->
  <div class="bg-primary-900 border-t border-primary-700 py-6">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <p class="text-xs text-slate-500 text-center leading-relaxed">
        <strong class="text-slate-400">Financial Disclaimer:</strong> This content is for educational purposes only and is not financial advice. Investing involves risk. <a href="/disclaimer" class="hover:text-accent-500 underline">Read full disclaimer</a>.
      </p>
    </div>
  </div>
</BaseLayout>
