---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BROKER_LINKS } from '../data/brokerLinks';
---

<BaseLayout title="Broker Finder | Get Global Yields">
<section class="w-full mt-6 px-4 pt-10 pb-10 sm:mt-8 sm:px-6 sm:pt-12 sm:pb-12 lg:mt-10 lg:px-8 lg:pt-14 lg:pb-14">
<div class="broker-finder-container">
    <!-- Header -->
    <div class="header">
        <div class="icon-circle">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
        </div>
        <h1>Find Your <span>Broker</span> by Country</h1>
        <p>Select your country of residence to see which brokers accept you - and compare them side by side.</p>
    </div>

    <!-- Country Selector -->
    <div class="selector-wrapper">
        <label for="country-select">Your Country of Residence</label>
        <div class="custom-select">
            <select id="country-select">
                <option value="">-- Select a country --</option>
            </select>
            <span class="arrow">
                <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
            </span>
        </div>
    </div>

    <!-- Results -->
    <div class="results-area" id="results-area">
        <div class="placeholder-state" id="placeholder">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <p>Select your country above to see available brokers</p>
        </div>
        <div id="results-content" style="display:none;"></div>
    </div>

</div>
<div class="disclaimer-wrapper">
    <div class="disclaimer">
        <strong>Disclaimer:</strong> Broker availability, fees, and features change frequently. The data shown is for informational purposes and may not reflect real-time conditions. Always verify directly with the broker before opening an account. Some links may be affiliate links - we may earn a commission at no extra cost to you.
    </div>
</div>
</section>
</BaseLayout>

<style>
    :root {
        --bg-primary: #0a192f;
        --bg-secondary: #112240;
        --bg-card: #112240;
        --border: #233554;
        --text-primary: #f1f5f9;
        --text-secondary: #cbd5e1;
        --text-muted: #94a3b8;
        --accent: #c9a84c;
        --accent-hover: #d4b55a;
        --accent-bg: rgba(201, 168, 76, 0.12);
        --accent-border: rgba(201, 168, 76, 0.35);
        --green: #22c55e;
        --red: #ef4444;
        --blue-accent: #1b3a6b;
        --shadow-lg: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    .broker-finder-container {
        width: 100%;
        max-width: 1100px;
        background: var(--bg-secondary);
        border-radius: 20px;
        border: 1px solid var(--border);
        padding: 40px 32px;
        box-shadow: var(--shadow-lg);
        margin: 24px auto 0;
    }

    .disclaimer-wrapper {
        width: 100%;
        max-width: 1100px;
        margin: 16px auto 20px;
    }

    .header {
        text-align: center;
        margin-bottom: 36px;
    }

    .header .icon-circle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: var(--accent-bg);
        border: 2px solid var(--accent-border);
        margin-bottom: 16px;
    }

    .header .icon-circle svg {
        width: 30px;
        height: 30px;
        color: var(--accent);
    }

    .header h1 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 6px;
        letter-spacing: -0.02em;
    }

    .header h1 span {
        color: var(--accent);
    }

    .header p {
        color: var(--text-muted);
        font-size: 1rem;
        max-width: 500px;
        margin: 0 auto;
    }

    .selector-wrapper {
        position: relative;
        margin-bottom: 32px;
    }

    .selector-wrapper label {
        display: block;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--text-secondary);
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .custom-select {
        position: relative;
        width: 100%;
    }

    .custom-select select {
        width: 100%;
        padding: 14px 48px 14px 18px;
        font-size: 1rem;
        font-family: inherit;
        background: var(--bg-primary);
        color: var(--text-primary);
        border: 2px solid var(--border);
        border-radius: 12px;
        appearance: none;
        -webkit-appearance: none;
        cursor: pointer;
        transition: all 0.2s ease;
        outline: none;
    }

    .custom-select select:hover {
        border-color: var(--accent-border);
    }

    .custom-select select:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 4px rgba(201, 168, 76, 0.15);
    }

    .custom-select .arrow {
        position: absolute;
        right: 16px;
        top: 50%;
        transform: translateY(-50%);
        pointer-events: none;
        color: var(--accent);
        transition: transform 0.2s ease;
    }

    .custom-select select:focus+.arrow {
        transform: translateY(-50%) rotate(180deg);
    }

    .results-area {
        min-height: 200px;
    }

    .placeholder-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-muted);
    }

    .placeholder-state svg {
        width: 80px;
        height: 80px;
        margin-bottom: 16px;
        opacity: 0.4;
    }

    .placeholder-state p {
        font-size: 1.05rem;
    }

    .results-count {
        font-size: 0.9rem;
        color: var(--text-muted);
        margin-bottom: 16px;
        font-weight: 500;
    }

    .results-count strong {
        color: var(--accent);
    }

    .table-container {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
        border-radius: 12px;
        border: 1px solid var(--border);
    }

    :global(table) {
        width: 100%;
        border-collapse: collapse;
        min-width: 650px;
    }

    :global(thead th) {
        background: var(--bg-primary);
        color: var(--text-muted);
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 14px 16px;
        text-align: left;
        border-bottom: 2px solid var(--border);
        white-space: nowrap;
    }

    :global(tbody td) {
        padding: 14px 16px;
        border-bottom: 1px solid var(--border);
        font-size: 0.9rem;
        color: var(--text-secondary);
        white-space: nowrap;
    }

    :global(tbody tr) {
        transition: background 0.15s ease;
    }

    :global(tbody tr:hover) {
        background: rgba(201, 168, 76, 0.04);
    }

    :global(tbody tr:last-child td) {
        border-bottom: none;
    }

    .broker-name {
        font-weight: 700;
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .broker-avatar {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: var(--accent-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.8rem;
        color: var(--accent);
        flex-shrink: 0;
    }

    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .badge-yes {
        background: rgba(34, 197, 94, 0.12);
        color: var(--green);
    }

    .badge-no {
        background: rgba(239, 68, 68, 0.1);
        color: var(--red);
    }

    .btn-open {
        display: inline-block;
        padding: 8px 18px;
        background: var(--accent);
        color: #0f172a;
        font-weight: 700;
        font-size: 0.8rem;
        text-decoration: none;
        border-radius: 8px;
        transition: all 0.2s ease;
        white-space: nowrap;
        letter-spacing: 0.01em;
    }

    .btn-open:hover {
        background: var(--accent-hover);
        transform: translateY(-1px);
        box-shadow: 0 4px 12px rgba(201, 168, 76, 0.3);
    }

    .disclaimer {
        margin-top: 24px;
        padding: 14px 18px;
        background: var(--bg-primary);
        border-radius: 10px;
        font-size: 0.78rem;
        color: var(--text-muted);
        border: 1px solid var(--border);
        line-height: 1.5;
    }

    @media (max-width: 768px) {
        .broker-finder-container {
            padding: 24px 16px;
            border-radius: 14px;
        }

        .header h1 {
            font-size: 1.5rem;
        }

        .header p {
            font-size: 0.9rem;
        }

        .custom-select select {
            padding: 12px 40px 12px 14px;
            font-size: 0.95rem;
        }

        :global(tbody td),
        :global(thead th) {
            padding: 10px 10px;
            font-size: 0.8rem;
        }

        .btn-open {
            padding: 6px 14px;
            font-size: 0.75rem;
        }
    }
</style>

<script define:vars={{ brokerLinks: BROKER_LINKS }}>
    (function() {
        // --- Country List (30+ countries from all regions) ---
        const countries = [
            { code: "AR", name: "Argentina" },
            { code: "AU", name: "Australia" },
            { code: "AT", name: "Austria" },
            { code: "BE", name: "Belgium" },
            { code: "BR", name: "Brazil" },
            { code: "CA", name: "Canada" },
            { code: "CL", name: "Chile" },
            { code: "CN", name: "China" },
            { code: "CO", name: "Colombia" },
            { code: "CZ", name: "Czech Republic" },
            { code: "DK", name: "Denmark" },
            { code: "EG", name: "Egypt" },
            { code: "FR", name: "France" },
            { code: "DE", name: "Germany" },
            { code: "GR", name: "Greece" },
            { code: "HK", name: "Hong Kong" },
            { code: "HU", name: "Hungary" },
            { code: "IN", name: "India" },
            { code: "ID", name: "Indonesia" },
            { code: "IE", name: "Ireland" },
            { code: "IL", name: "Israel" },
            { code: "IT", name: "Italy" },
            { code: "JP", name: "Japan" },
            { code: "MY", name: "Malaysia" },
            { code: "MX", name: "Mexico" },
            { code: "NL", name: "Netherlands" },
            { code: "NZ", name: "New Zealand" },
            { code: "NG", name: "Nigeria" },
            { code: "NO", name: "Norway" },
            { code: "PE", name: "Peru" },
            { code: "PH", name: "Philippines" },
            { code: "PL", name: "Poland" },
            { code: "PT", name: "Portugal" },
            { code: "RO", name: "Romania" },
            { code: "RU", name: "Russia" },
            { code: "SA", name: "Saudi Arabia" },
            { code: "SG", name: "Singapore" },
            { code: "ZA", name: "South Africa" },
            { code: "KR", name: "South Korea" },
            { code: "ES", name: "Spain" },
            { code: "SE", name: "Sweden" },
            { code: "CH", name: "Switzerland" },
            { code: "TW", name: "Taiwan" },
            { code: "TH", name: "Thailand" },
            { code: "TR", name: "Turkey" },
            { code: "UA", name: "Ukraine" },
            { code: "AE", name: "United Arab Emirates" },
            { code: "GB", name: "United Kingdom" },
            { code: "US", name: "United States" },
            { code: "VN", name: "Vietnam" },
        ];

        // --- Broker Database ---
        const brokers = [
            { id: "ibkr", name: "Interactive Brokers", minDeposit: "\$0", commission: "\$0.005/share", w8ben: true,
                url: brokerLinks.ibkr },
            { id: "schwab", name: "Charles Schwab", minDeposit: "\$0", commission: "\$0/stock trade", w8ben: true,
                url: brokerLinks.schwab },
            { id: "fidelity", name: "Fidelity", minDeposit: "\$0", commission: "\$0/stock trade", w8ben: true,
                url: brokerLinks.fidelity },
            { id: "tastytrade", name: "tastytrade", minDeposit: "\$0", commission: "\$0/stock, \$1/option", w8ben: true,
                url: brokerLinks.tastytrade },
            { id: "firstrade", name: "Firstrade", minDeposit: "\$0", commission: "\$0/stock trade", w8ben: true,
                url: brokerLinks.firstrade },
            { id: "etrade", name: "E*TRADE", minDeposit: "\$0", commission: "\$0/stock trade", w8ben: true,
                url: brokerLinks.etrade },
            { id: "tdameritrade", name: "TD Ameritrade", minDeposit: "\$0", commission: "\$0/stock trade", w8ben: true,
                url: brokerLinks.tdAmeritrade },
            { id: "webull", name: "Webull", minDeposit: "\$0", commission: "\$0/stock trade", w8ben: false,
                url: brokerLinks.webull },
            { id: "robinhood", name: "Robinhood", minDeposit: "\$0", commission: "\$0/stock trade", w8ben: false,
                url: "https://www.robinhood.com/" },
            { id: "xtb", name: "XTB", minDeposit: "\$0", commission: "Spread-based", w8ben: false,
                url: brokerLinks.xtb },
            { id: "etoro", name: "eToro", minDeposit: "\$50", commission: "Spread-based", w8ben: false,
                url: brokerLinks.etoro },
            { id: "degiro", name: "DEGIRO", minDeposit: "\$0", commission: "€0.50 + 0.004/share", w8ben: false,
                url: brokerLinks.degiro },
            { id: "saxo", name: "Saxo Bank", minDeposit: "\$2,000", commission: "0.08% (min \$3)", w8ben: true,
                url: brokerLinks.saxo },
            { id: "swissquote", name: "Swissquote", minDeposit: "\$1,000", commission: "0.1% (min \$15)", w8ben: true,
                url: brokerLinks.swissquote },
        ];

        // --- Country → Broker availability mapping (realistic sample data) ---
        // Using broker IDs from the brokers array above
        const countryBrokerMap = {
            // North America
            US: ["ibkr", "schwab", "fidelity", "tastytrade", "firstrade", "etrade", "tdameritrade", "webull",
                "robinhood"
            ],
            CA: ["ibkr", "tastytrade", "firstrade", "etrade", "tdameritrade", "webull", "xtb", "etoro"],
            MX: ["ibkr", "tastytrade", "firstrade", "etoro", "xtb", "webull"],

            // South America
            BR: ["ibkr", "tastytrade", "etoro", "xtb", "firstrade"],
            AR: ["ibkr", "etoro", "xtb"],
            CL: ["ibkr", "etoro", "firstrade"],
            CO: ["ibkr", "etoro", "xtb", "firstrade"],
            PE: ["ibkr", "etoro", "xtb"],

            // Western Europe
            GB: ["ibkr", "tastytrade", "firstrade", "schwab", "saxo", "degiro", "etoro", "xtb"],
            DE: ["ibkr", "tastytrade", "firstrade", "saxo", "degiro", "etoro", "xtb", "swissquote"],
            FR: ["ibkr", "tastytrade", "firstrade", "saxo", "degiro", "etoro", "xtb"],
            IT: ["ibkr", "firstrade", "saxo", "degiro", "etoro", "xtb"],
            ES: ["ibkr", "firstrade", "saxo", "degiro", "etoro", "xtb"],
            NL: ["ibkr", "tastytrade", "firstrade", "saxo", "degiro", "etoro", "xtb"],
            BE: ["ibkr", "saxo", "degiro", "etoro", "xtb"],
            AT: ["ibkr", "saxo", "degiro", "etoro", "xtb", "swissquote"],
            CH: ["ibkr", "tastytrade", "saxo", "swissquote", "degiro", "etoro"],
            IE: ["ibkr", "tastytrade", "firstrade", "saxo", "degiro", "etoro"],
            PT: ["ibkr", "firstrade", "saxo", "degiro", "etoro", "xtb"],
            GR: ["ibkr", "saxo", "etoro", "xtb"],
            DK: ["ibkr", "saxo", "degiro", "etoro", "xtb"],
            SE: ["ibkr", "tastytrade", "saxo", "degiro", "etoro", "xtb"],
            NO: ["ibkr", "saxo", "degiro", "etoro", "xtb"],

            // Eastern Europe
            PL: ["ibkr", "firstrade", "xtb", "etoro", "degiro"],
            CZ: ["ibkr", "xtb", "etoro", "degiro", "firstrade"],
            HU: ["ibkr", "xtb", "etoro", "firstrade"],
            RO: ["ibkr", "xtb", "etoro", "firstrade"],
            UA: ["ibkr", "xtb", "etoro"],
            RU: ["ibkr", "etoro"],

            // Asia
            JP: ["ibkr", "firstrade", "saxo", "etoro"],
            CN: ["ibkr", "firstrade", "etoro"],
            HK: ["ibkr", "tastytrade", "firstrade", "saxo", "etoro", "webull"],
            SG: ["ibkr", "tastytrade", "firstrade", "saxo", "etoro", "webull", "tdameritrade"],
            KR: ["ibkr", "firstrade", "etoro"],
            TW: ["ibkr", "firstrade", "etoro", "webull"],
            IN: ["ibkr", "firstrade", "etoro", "xtb", "webull"],
            ID: ["ibkr", "firstrade", "etoro", "webull"],
            MY: ["ibkr", "firstrade", "etoro", "webull"],
            PH: ["ibkr", "firstrade", "etoro", "webull"],
            TH: ["ibkr", "firstrade", "etoro", "webull"],
            VN: ["ibkr", "firstrade", "etoro"],

            // Middle East & Africa
            IL: ["ibkr", "tastytrade", "firstrade", "etoro", "xtb"],
            AE: ["ibkr", "tastytrade", "firstrade", "saxo", "etoro", "xtb", "swissquote"],
            SA: ["ibkr", "firstrade", "saxo", "etoro", "xtb"],
            TR: ["ibkr", "etoro", "xtb", "firstrade"],
            EG: ["ibkr", "etoro", "xtb"],
            ZA: ["ibkr", "tastytrade", "firstrade", "etoro", "xtb", "saxo"],
            NG: ["ibkr", "etoro", "xtb"],

            // Oceania
            AU: ["ibkr", "tastytrade", "firstrade", "schwab", "saxo", "etoro", "webull"],
            NZ: ["ibkr", "tastytrade", "firstrade", "saxo", "etoro", "webull"],
        };

        // --- DOM Elements ---
        const selectEl = document.getElementById('country-select');
        const placeholderEl = document.getElementById('placeholder');
        const resultsContentEl = document.getElementById('results-content');

        // --- Populate country dropdown ---
        countries.sort((a, b) => a.name.localeCompare(b.name));
        countries.forEach(country => {
            const option = document.createElement('option');
            option.value = country.code;
            option.textContent = country.name;
            selectEl.appendChild(option);
        });

        // --- Handle selection ---
        selectEl.addEventListener('change', function() {
            const selectedCode = this.value;

            if (!selectedCode) {
                placeholderEl.style.display = 'block';
                resultsContentEl.style.display = 'none';
                resultsContentEl.innerHTML = '';
                return;
            }

            const country = countries.find(c => c.code === selectedCode);
            const brokerIds = countryBrokerMap[selectedCode] || [];
            const availableBrokers = brokerIds
                .map(id => brokers.find(b => b.id === id))
                .filter(Boolean);

            // Render results
            if (availableBrokers.length === 0) {
                resultsContentEl.innerHTML = `
                        <div class="placeholder-state">
                            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            <p>No broker data available for ${country.name} yet.<br>Check back soon or contact us for a recommendation.</p>
                        </div>`;
            } else {
                const rowsHTML = availableBrokers.map(b => `
                        <tr>
                            <td>
                                <span class="broker-name">
                                    <span class="broker-avatar">${b.name.charAt(0)}</span>
                                    ${b.name}
                                </span>
                            </td>
                            <td>${b.minDeposit}</td>
                            <td>${b.commission}</td>
                            <td><span class="badge ${b.w8ben ? 'badge-yes' : 'badge-no'}">${b.w8ben ? 'Yes' : 'No'}</span></td>
                            <td><a href="${b.url}" target="_blank" rel="noopener noreferrer" class="btn-open">Open Account →</a></td>
                        </tr>
                    `).join('');

                resultsContentEl.innerHTML = `
                        <div class="results-count">
                            <strong>${availableBrokers.length}</strong> broker${availableBrokers.length !== 1 ? 's' : ''} available for <strong>${country.name}</strong>
                        </div>
                        <div class="table-container">
                            <table>
                                <thead>
                                    <tr>
                                        <th>Broker</th>
                                        <th>Min Deposit</th>
                                        <th>Commission</th>
                                        <th>W-8BEN Support</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    ${rowsHTML}
                                </tbody>
                            </table>
                        </div>`;
            }

            placeholderEl.style.display = 'none';
            resultsContentEl.style.display = 'block';
        });
    })();
</script>
