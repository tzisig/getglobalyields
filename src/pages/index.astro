---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import NewsletterForm from '../components/NewsletterForm.astro';

const allPosts = [
  ...(await getCollection('best-brokers')).map(p => ({ ...p, type: 'best-brokers' })),
  ...(await getCollection('strategies')).map(p => ({ ...p, type: 'strategies' })),
  ...(await getCollection('taxes')).map(p => ({ ...p, type: 'taxes' })),
  ...(await getCollection('us-investing')).map(p => ({ ...p, type: 'us-investing' })),
].filter(post => !post.data.draft);

const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="US Markets for Non-US Investors - Get Global Yields"
  description="Real case studies, broker reviews, and tax guides for investors outside the US. Based on actual portfolios and public data."
>
  <!-- Hero Section -->
  <section class="relative bg-primary-900 border-b border-primary-700 overflow-hidden">
    <div class="absolute inset-x-0 top-0 h-96 bg-gradient-to-b from-primary-800 to-transparent opacity-50"></div>
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-accent-500/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 -left-24 w-72 h-72 bg-blue-500/10 rounded-full blur-3xl"></div>

    <div class="container relative mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block mb-5 rounded-full border border-accent-500/30 bg-accent-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-accent-500">
            Written for Non-US Investors
          </span>
          <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-slate-100 tracking-tight mb-6">
            US Markets, <span class="text-accent-500">for Non-US Investors</span>
          </h1>
          <!-- <div class="max-w-2xl mb-6">
            <NewsletterForm compact={true} />
          </div> -->
          <p class="text-xl sm:text-2xl font-semibold text-slate-300 mb-4 max-w-2xl">
            Best brokers, tax strategies & options income methods and case study built for non-US investors.
          </p>
          <p class="text-lg sm:text-xl text-slate-200 mb-10 max-w-2xl leading-relaxed">
            Compare Top Brokers • Options Income Strategies • Made for Non-US Investors
          </p>
          <div class="flex flex-wrap gap-4 mb-8">
            <a href="/best-brokers/" class="inline-flex items-center justify-center px-8 py-4 border border-transparent text-lg font-bold rounded-md text-primary-900 bg-accent-500 hover:bg-accent-400 shadow-lg shadow-accent-500/30 transition-all duration-200 hover:-translate-y-1">
              Compare Brokers →
            </a>
            <a href="/start-here/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-primary-600 text-lg font-bold rounded-md text-slate-100 bg-transparent hover:bg-primary-800 hover:border-primary-500 transition-all duration-200">
              Start Here
            </a>
          </div>
          <p class="text-sm text-slate-300">No sponsored rankings. No broker pays for rankings or placement.</p>
        </div>
        <div class="hidden lg:flex items-center justify-center">
          <img src="/images/hero-globe-dark.svg" alt="Global investing illustration" width="680" height="520" class="w-full max-w-2xl theme-dark-only" fetchpriority="high" />
          <img src="/images/hero-globe-light.svg" alt="Global investing illustration" width="680" height="520" class="w-full max-w-2xl theme-light-only" fetchpriority="high" />
        </div>
        
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="bg-primary-800 border-b border-primary-700 py-6 min-h-[120px]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl font-bold text-accent-500">50+</p>
          <p class="text-sm text-slate-200 mt-1">Guides Published</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-accent-500">200+</p>
          <p class="text-sm text-slate-200 mt-1">Countries Covered</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-accent-500">5,000+</p>
          <p class="text-sm text-slate-200 mt-1">Monthly Readers</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-accent-500">$0</p>
          <p class="text-sm text-slate-200 mt-1">Paid Placements</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Social Proof / Story Block -->
  <section class="py-16 bg-primary-900 border-b border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
      <div class="bg-primary-800 border border-accent-500/30 rounded-2xl p-8 lg:p-12 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-accent-500/5 rounded-full blur-3xl"></div>
        <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div>
            <span class="inline-block mb-4 text-xs font-bold uppercase tracking-widest text-accent-500 border border-accent-500/30 rounded-full px-3 py-1">
              Real Case Study
            </span>
            <h2 class="text-3xl lg:text-4xl font-bold text-slate-100 mb-4 leading-tight">
              From <span class="text-red-400">−70% Drawdown</span> to <span class="text-accent-500">+$492K</span>
            </h2>
            <p class="text-slate-300 text-lg leading-relaxed mb-6">
              A full breakdown of a TQQQ position: where the thesis broke, what the recovery plan actually looked like, and the numbers at each step. Includes the mistakes.
            </p>
            <a href="/case-study/from-minus-70-to-plus-492k-real-tqqq-recovery-case-study/" class="inline-flex items-center text-accent-500 font-bold hover:text-accent-400 transition-colors">
              Read the case study
              <svg class="w-4 h-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              { label: 'Starting Loss', value: '−70%', color: 'text-red-400' },
              { label: 'Final Gain', value: '+$492K', color: 'text-accent-500' },
              { label: 'Strategy', value: 'TQQQ', color: 'text-blue-400' },
              { label: 'Broker Used', value: 'IBKR', color: 'text-slate-100' },
            ].map(stat => (
              <div class="bg-primary-900 rounded-xl p-5 border border-primary-700 text-center">
                <p class={`text-2xl font-bold mb-1 ${stat.color}`}>{stat.value}</p>
                <p class="text-xs text-slate-300 uppercase tracking-wider">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Intent Funnels Section -->
  <section class="py-20 lg:py-28 bg-primary-800 relative overflow-hidden">
    <div class="absolute top-0 right-1/4 w-64 h-64 bg-accent-500/5 rounded-full blur-3xl"></div>
    <div class="container relative mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-bold text-slate-100 inline-block relative">
          Where Do You Want To Start?
          <span class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-16 h-1.5 bg-accent-500 rounded-full"></span>
        </h2>
        <p class="mt-8 text-slate-200 max-w-2xl mx-auto text-lg">Pick the section that matches your situation. Each one is written with non-US residency in mind.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 xl:gap-10">
        {[
          { title: 'Best Brokers', count: '9 guides', desc: 'Broker comparisons by country, with actual fees, market access, and account opening notes.', href: '/best-brokers/', icon: 'M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H14' },
          { title: 'Start Here', count: 'Begin with the basics', desc: 'A plain walkthrough for investors new to US markets from outside the United States.', href: '/start-here/', icon: 'M13 10V3L4 14h7v7l9-11h-7z' },
          { title: 'US Investing', count: '9 guides', desc: 'How non-US residents actually open accounts and buy US stocks, ETFs, and options.', href: '/us-investing/', icon: 'M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3' },
          { title: 'Options Income', count: '9 guides', desc: 'Covered calls and cash-secured puts with the assumptions, math, and risk clearly shown.', href: '/options-income/', icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z' },
          { title: 'Taxes', count: '8 guides', desc: 'W-8BEN, dividend withholding, and treaty rates explained without the legal filler.', href: '/taxes/', icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z' },
          { title: 'Strategies', count: '19 guides', desc: 'Leveraged ETFs, dividend funds, and TQQQ research with the tradeoffs laid out.', href: '/strategies/', icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6' },
          { title: 'Case Study', count: 'Real portfolios', desc: 'Write-ups of actual trades and outcomes, including the positions that did not work.', href: '/case-studies/', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
          { title: 'Broker Finder', count: 'Match your country', desc: 'Find which brokers accept investors from your country, compared side by side.', href: '/resources/broker-finder/', icon: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418' },
          { title: 'Tax Map', count: 'Treaty rates visual', desc: 'Interactive world map of US tax treaty status, withholding rates, and W-8BEN requirements.', href: '/resources/tax-map/', icon: 'M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7' }
        ].map((cat, index) => (
          <a href={cat.href} class={`group p-8 rounded-2xl border transition-all duration-300 hover:-translate-y-2 flex flex-col items-center text-center ${
            index === 0
              ? 'md:col-span-2 lg:col-span-3 bg-primary-800 border-accent-500 hover:border-accent-400 hover:shadow-xl hover:shadow-accent-500/20 shadow-lg shadow-accent-500/10'
              : 'bg-primary-900 border-primary-700 hover:border-accent-500 hover:shadow-xl hover:shadow-accent-500/20'
          }`}>
            {index === 0 && (
              <span class="inline-block px-4 py-1.5 rounded-full bg-accent-500/10 text-accent-400 text-sm font-bold tracking-wider uppercase mb-6 border border-accent-500/20">
                New Here? Start With This
              </span>
            )}
            <div class={`w-20 h-20 rounded-2xl bg-primary-800 rotate-3 group-hover:rotate-6 flex items-center justify-center mb-6 group-hover:bg-accent-500 group-hover:text-primary-900 transition-all duration-300 shadow-inner ${index === 0 ? 'text-accent-400 bg-primary-900' : 'text-accent-500'}`}>
              <svg class="w-10 h-10 -rotate-3 group-hover:-rotate-6 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={cat.icon} />
              </svg>
            </div>
            <h3 class={`font-bold text-slate-100 mb-3 group-hover:text-accent-500 transition-colors ${index === 0 ? 'text-3xl' : 'text-2xl'}`}>{cat.title}</h3>
            <p class={`text-slate-200 group-hover:text-slate-300 transition-colors leading-relaxed ${index === 0 ? 'text-lg md:text-xl max-w-2xl' : 'text-base md:text-lg'}`}>{cat.desc}</p>
            <span class="mt-4 inline-block text-xs font-bold uppercase tracking-wider text-accent-500/70 border border-accent-500/20 rounded-full px-3 py-1">
              {cat.count}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Latest Articles Section -->
  <section class="py-20 lg:py-24 bg-primary-900 border-t border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-100 inline-block relative">
          Latest Articles
          <span class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-16 h-1.5 bg-accent-500 rounded-full"></span>
        </h2>
        <p class="mt-8 text-slate-200 max-w-xl mx-auto text-lg">New research and notes, written for investors outside the US.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {latestPosts.map((post) => {
          const heroImage = post.data.heroImage;
          const heroImageLight = post.data.heroImageLight || (heroImage ? heroImage.replace('/images/blog/', '/images/blog/light/') : '');
          const heroImageDark = post.data.heroImageDark || heroImage || '';

          return (
            <a href={`/${post.type}/${post.id}/`} class="group bg-primary-800 border border-primary-700 rounded-2xl overflow-hidden hover:border-accent-500 hover:shadow-xl hover:shadow-accent-500/10 transition-all duration-300 hover:-translate-y-1 flex flex-col">
              {heroImage && (
                <div class="w-full h-48 overflow-hidden">
                  {heroImageLight && (
                    <img
                      src={heroImageLight}
                      alt={post.data.title}
                      class="w-full h-48 object-cover theme-light-only"
                      loading="lazy"
                    />
                  )}
                  {heroImageDark && (
                    <img
                      src={heroImageDark}
                      alt={post.data.title}
                      class="w-full h-48 object-cover theme-dark-only"
                      loading="lazy"
                    />
                  )}
                </div>
              )}
              <div class="p-6 flex flex-col flex-1">
                <span class="text-xs font-bold uppercase tracking-wider text-accent-500 mb-3">{post.type}</span>
                <h3 class="text-lg font-bold text-slate-100 mb-3 group-hover:text-accent-500 transition-colors leading-snug">{post.data.title}</h3>
                <p class="text-sm text-slate-200 leading-relaxed flex-1">{post.data.description}</p>
                <div class="mt-4 flex items-center text-accent-500 text-sm font-semibold">
                  Read article
                  <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div class="text-center mt-12">
        <a href="/start-here/" class="inline-flex items-center justify-center px-8 py-4 border-2 border-primary-600 text-lg font-bold rounded-md text-slate-100 bg-transparent hover:bg-primary-800 hover:border-accent-500 transition-all duration-200">
          Browse all articles
        </a>
      </div>
    </div>
  </section>

  <!-- Why Us Section -->
  <section class="py-20 lg:py-24 bg-primary-800 border-t border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-100 inline-block relative">
          What This Site Is
          <span class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-16 h-1.5 bg-accent-500 rounded-full"></span>
        </h2>
        <p class="mt-8 text-slate-200 max-w-2xl mx-auto text-lg">Built around a non-US investor perspective from the start. Not US content with a translation layer on top.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z', title: 'Independent', desc: 'No broker pays for rankings. Ordering is based on actual fees, available markets, and account access.' },
          { icon: 'M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064', title: 'Non-US Lens', desc: 'Residency, tax treaty, and broker access are treated as primary constraints, not footnotes.' },
          { icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', title: 'Specific Topics', desc: 'W-8BEN, dividend withholding, leverage decay, and options income - each topic is handled in depth.' },
          { icon: 'M13 7h8m0 0v8m0-8l-8 8-4-4-6 6', title: 'Real Numbers', desc: 'Case studies come from live portfolios and public data, not idealized backtests or rounded summaries.' },
        ].map(item => (
          <div class="flex flex-col items-center text-center p-6 bg-primary-900 rounded-2xl border border-primary-700 hover:border-accent-500/50 transition-colors">
            <div class="w-14 h-14 rounded-xl bg-accent-500/10 flex items-center justify-center mb-5 text-accent-500">
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={item.icon} />
              </svg>
            </div>
            <h3 class="text-lg font-bold text-slate-100 mb-3">{item.title}</h3>
            <p class="text-slate-200 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-20 lg:py-24 bg-primary-900 border-t border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-slate-100 inline-block relative">
          Frequently Asked Questions
          <span class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-16 h-1.5 bg-accent-500 rounded-full"></span>
        </h2>
      </div>
      <div class="space-y-4">
        {[
          { q: 'Can I invest in US stocks if I live outside the US?', a: 'Yes. Non-US residents can legally hold US stocks and ETFs through brokers that accept international accounts, such as Interactive Brokers, eToro, and Saxo. You file a W-8BEN with the broker so any reduced treaty rate can be applied to dividends.' },
          { q: 'Which broker works best for non-US investors?', a: 'For most people, Interactive Brokers offers the strongest combination of low fees, broad market access (150+ markets, 200+ countries), and serious tools. eToro is simpler to start with. The right fit depends on your country of residence, the assets you need, and how active you plan to be.' },
          { q: 'How much US tax applies to dividends for non-residents?', a: 'The default US withholding on dividends paid to non-residents is 30%. A valid W-8BEN combined with a tax treaty can reduce that rate, often to 15%. Your country of residence may still tax the same dividend separately, so the effective rate depends on both jurisdictions.' },
          { q: 'Is TQQQ safe to hold long term?', a: 'TQQQ is a 3x leveraged ETF. It can compound strongly during sustained uptrends, but volatility decay and deep drawdowns in bear markets are real. It is not a passive buy-and-forget holding and needs active position sizing and risk management.' },
          { q: 'Is the site actually independent?', a: 'Yes. No broker pays for ranking or placement. Some links are affiliate links and may earn a commission if you sign up, but that does not change what gets ranked first or what the content says.' },
        ].map(item => (
          <details class="group bg-primary-800 border border-primary-700 rounded-xl overflow-hidden hover:border-accent-500/50 transition-colors">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="font-semibold text-slate-100 group-hover:text-accent-500 transition-colors pr-4">{item.q}</span>
              <svg class="w-5 h-5 text-accent-500 shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6">
              <p class="text-slate-200 leading-relaxed">{item.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 bg-primary-900 border-t border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <NewsletterForm />
      </div>
    </div>
  </section>


</BaseLayout>
