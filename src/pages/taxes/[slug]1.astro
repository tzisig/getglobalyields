---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import Sidebar from '../../components/Sidebar.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';

export async function getStaticPaths() {
  const posts = await getCollection('taxes').catch(() => []);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
if (!post) return Astro.redirect('/404');
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title} — Get Global Yields`}
  description={post.data.description}
  image={post.data.heroImage}
>
  <!-- Article hero bar — stays navy for brand consistency -->
  <div class="bg-primary-800 border-b border-primary-700 py-10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="lg:max-w-[66%]">
        {post.data.categories && post.data.categories.length > 0 && (
          <span class="inline-block bg-accent-500 text-primary-900 text-xs font-bold px-3 py-1 rounded uppercase tracking-wider mb-4">
            {post.data.categories[0]}
          </span>
        )}
        <h1 class="text-3xl md:text-4xl font-bold text-slate-100 tracking-tight mb-4 leading-snug">
          {post.data.title}
        </h1>
        <div class="flex items-center text-slate-400 text-sm gap-3">
          <time datetime={post.data.pubDate.toISOString()}>
            {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span>&bull;</span>
          <span>By {post.data.author}</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Main content area — light background -->
  <div class="bg-[#f8fafc] border-b border-slate-200">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl py-12">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">

        <!-- Article body -->
        <div class="lg:col-span-2">

          <!-- Affiliate disclaimer — restyled for light bg -->
          <div class="bg-white border border-slate-200 rounded-lg p-4 mb-8 text-sm text-slate-500 leading-relaxed shadow-sm">
            <p>
              <strong class="text-slate-700">Disclosure:</strong> This article may contain affiliate links. If you click and make a purchase or open an account, we may earn a commission at no extra cost to you. See our{' '}
              <a href="/disclaimer" class="text-accent-600 hover:underline">full disclosure policy</a>.
            </p>
          </div>

          <!-- Ad Top -->
          <div class="w-full my-8 bg-slate-100 border-2 border-dashed border-slate-300 p-4 flex justify-center items-center text-slate-400 rounded-lg min-h-[100px]">
            <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
          </div>

          {post.data.heroImage && (
            <img
              src={post.data.heroImage}
              alt={post.data.title}
              class="w-full h-auto rounded-xl mb-10 shadow-md border border-slate-200"
            />
          )}

          <!-- Ad Middle -->
          <div class="w-full my-8 bg-slate-100 border-2 border-dashed border-slate-300 p-4 flex justify-center items-center text-slate-400 rounded-lg min-h-[100px]">
            <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
          </div>

          <!-- Prose — light mode typography -->
          <div class="
            prose prose-lg max-w-none
            prose-headings:text-[#0f172a] prose-headings:font-bold prose-headings:tracking-tight
            prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
            prose-p:text-[#334155] prose-p:leading-relaxed prose-p:mb-5
            prose-li:text-[#334155] prose-li:leading-relaxed
            prose-a:text-accent-600 hover:prose-a:text-accent-500 prose-a:no-underline hover:prose-a:underline
            prose-strong:text-[#0f172a] prose-strong:font-semibold
            prose-blockquote:border-l-accent-500 prose-blockquote:bg-slate-50 prose-blockquote:rounded-r-lg prose-blockquote:py-1
            prose-code:text-accent-700 prose-code:bg-slate-100 prose-code:px-1 prose-code:rounded
            prose-table:text-sm
            prose-thead:bg-[#1B3A6B] prose-th:text-white prose-th:font-bold prose-th:py-3 prose-th:px-4
            prose-td:text-slate-700 prose-td:py-3 prose-td:px-4 prose-td:border-b prose-td:border-slate-200
          ">
            <Content />
          </div>

          <!-- Ad Bottom -->
          <div class="w-full my-8 bg-slate-100 border-2 border-dashed border-slate-300 p-4 flex justify-center items-center text-slate-400 rounded-lg min-h-[100px]">
            <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
          </div>

          <!-- Author Bio — restyled for light bg -->
          <div class="mt-12 bg-white rounded-2xl p-6 sm:p-8 border border-slate-200 shadow-sm flex flex-col sm:flex-row items-center sm:items-start gap-6">
            <div class="shrink-0">
              <div class="w-20 h-20 rounded-full border-2 border-accent-500 overflow-hidden shadow">
                <img src="/theauthor.png" alt={post.data.author} class="w-full h-full object-cover" />
              </div>
            </div>
            <div class="text-center sm:text-left flex-1">
              <h3 class="text-lg font-bold text-[#0f172a] mb-2">Written by {post.data.author}</h3>
              <p class="text-[#334155] text-sm leading-relaxed">
                Leveraging over 20 years of expertise as a software developer, I apply a rigorous analytical and systems-driven mindset to the world of high-yield investing. I specialize in leveraged ETFs (TQQQ) and advanced options strategies, focusing on generating consistent returns through data-driven risk management and technical market analysis.
              </p>
            </div>
          </div>

        </div>

        <!-- Sidebar — stays dark, looks great against light article -->
        <div class="hidden lg:block lg:col-span-1">
          <Sidebar />
        </div>

      </div>
    </div>
  </div>

</BaseLayout>
