---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us - Get Global Yields"
  description="Get in touch with the Get Global Yields team."
>
  <div class="bg-primary-900 py-16 lg:py-24">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight mb-8">Contact Us</h1>
      <p class="text-lg text-slate-300 mb-12">
        Have a question, feedback, or a partnership inquiry? We'd love to hear from you. Fill out the form below and our team will get back to you as soon as possible.
      </p>

      <div class="bg-primary-800 rounded-2xl p-6 sm:p-10 border border-primary-700 shadow-xl">
        <form class="space-y-6" action="https://formsubmit.co/eladreck@gmail.com" method="POST">
          <input type="hidden" name="_subject" value="New Contact Form Message">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="first-name" class="block text-sm font-medium text-slate-300 mb-2">First name</label>
              <input type="text" name="first-name" id="first-name" class="block w-full rounded-md bg-primary-900 border border-primary-600 text-slate-100 px-4 py-3 focus:border-accent-500 focus:ring-accent-500 transition-colors" placeholder="John" required>
            </div>
            <div>
              <label for="last-name" class="block text-sm font-medium text-slate-300 mb-2">Last name</label>
              <input type="text" name="last-name" id="last-name" class="block w-full rounded-md bg-primary-900 border border-primary-600 text-slate-100 px-4 py-3 focus:border-accent-500 focus:ring-accent-500 transition-colors" placeholder="Doe" required>
            </div>
          </div>
          
          <div>
            <label for="email" class="block text-sm font-medium text-slate-300 mb-2">Email address</label>
            <input type="email" name="email" id="email" class="block w-full rounded-md bg-primary-900 border border-primary-600 text-slate-100 px-4 py-3 focus:border-accent-500 focus:ring-accent-500 transition-colors" placeholder="john@example.com" required>
          </div>
          
          <div>
            <label for="subject" class="block text-sm font-medium text-slate-300 mb-2">Subject</label>
            <input type="text" name="subject" id="subject" class="block w-full rounded-md bg-primary-900 border border-primary-600 text-slate-100 px-4 py-3 focus:border-accent-500 focus:ring-accent-500 transition-colors" placeholder="How can we help?" required>
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-slate-300 mb-2">Message</label>
            <textarea id="message" name="message" rows="6" class="block w-full rounded-md bg-primary-900 border border-primary-600 text-slate-100 px-4 py-3 focus:border-accent-500 focus:ring-accent-500 transition-colors" placeholder="Leave your message here..." required></textarea>
          </div>

          <div>
            <button type="submit" class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-base font-medium text-primary-900 bg-accent-500 hover:bg-accent-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent-500 focus:ring-offset-primary-900 transition-colors">
              Send Message
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>
