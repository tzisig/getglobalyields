        USA: { name: "United States", flag: "????", status: "full", rate: "0%", estateTax: "No", w8ben: "No", guide: "/taxes/united-states" },
      };
      const iso3ToIso2 = {
        AUS: "au", AUT: "at", BEL: "be", BGR: "bg", CAN: "ca", CHN: "cn", CZE: "cz", DNK: "dk", EGY: "eg", EST: "ee",
        FIN: "fi", FRA: "fr", DEU: "de", GRC: "gr", HUN: "hu", ISL: "is", IND: "in", IDN: "id", IRL: "ie", ISR: "il",
        ITA: "it", JPN: "jp", KOR: "kr", LVA: "lv", LTU: "lt", LUX: "lu", MYS: "my", MEX: "mx", NLD: "nl", NZL: "nz",
        NOR: "no", PHL: "ph", POL: "pl", PRT: "pt", ROU: "ro", RUS: "ru", SVK: "sk", SVN: "si", ZAF: "za", ESP: "es",
        SWE: "se", CHE: "ch", THA: "th", TUR: "tr", UKR: "ua", GBR: "gb", VEN: "ve", ARG: "ar", BRA: "br", CHL: "cl",
        COL: "co", ARE: "ae", SGP: "sg", SAU: "sa", NGA: "ng", USA: "us"
      };

      const width = 960;
      const height = 500;
      const svg = d3.select('#map-svg');
      const tooltip = d3.select('#tooltip-map');
      const mapWrapper = document.getElementById('map-wrapper');
      const sidebarPlaceholder = document.getElementById('sidebar-placeholder');
      const sidebarContent = document.getElementById('sidebar-content');
      let selectedCountryCode = null;

      const projection = d3.geoMercator()
        .scale(140)
        .translate([width / 2, height / 1.55]);
      const path = d3.geoPath().projection(projection);

      function getISO3(id) {
        const idMap = {
          '004': 'AFG','008': 'ALB','012': 'DZA','020': 'AND','024': 'AGO','028': 'ATG','032': 'ARG','036': 'AUS','040': 'AUT','044': 'BHS','048': 'BHR','050': 'BGD','051': 'ARM','052': 'BRB','056': 'BEL','060': 'BMU','064': 'BTN','068': 'BOL','070': 'BIH','072': 'BWA','076': 'BRA','084': 'BLZ','086': 'IOT','090': 'SLB','092': 'VGB','096': 'BRN','100': 'BGR','104': 'MMR','108': 'BDI','112': 'BLR','116': 'KHM','120': 'CMR','124': 'CAN','132': 'CPV','140': 'CAF','144': 'LKA','148': 'TCD','152': 'CHL','156': 'CHN','158': 'TWN','170': 'COL','174': 'COM','178': 'COG','180': 'COD','184': 'COK','188': 'CRI','191': 'HRV','192': 'CUB','196': 'CYP','203': 'CZE','204': 'BEN','208': 'DNK','212': 'DMA','214': 'DOM','218': 'ECU','222': 'SLV','226': 'GNQ','231': 'ETH','232': 'ERI','233': 'EST','234': 'FRO','238': 'FLK','242': 'FJI','246': 'FIN','248': 'ALA','250': 'FRA','254': 'GUF','258': 'PYF','262': 'DJI','266': 'GAB','268': 'GEO','270': 'GMB','275': 'PSE','276': 'DEU','288': 'GHA','292': 'GIB','296': 'KIR','300': 'GRC','304': 'GRL','308': 'GRD','312': 'GLP','316': 'GUM','320': 'GTM','324': 'GIN','328': 'GUY','332': 'HTI','336': 'VAT','340': 'HND','344': 'HKG','348': 'HUN','352': 'ISL','356': 'IND','360': 'IDN','364': 'IRN','368': 'IRQ','372': 'IRL','376': 'ISR','380': 'ITA','384': 'CIV','388': 'JAM','392': 'JPN','398': 'KAZ','400': 'JOR','404': 'KEN','408': 'PRK','410': 'KOR','414': 'KWT','417': 'KGZ','418': 'LAO','422': 'LBN','426': 'LSO','428': 'LVA','430': 'LBR','434': 'LBY','438': 'LIE','440': 'LTU','442': 'LUX','446': 'MAC','450': 'MDG','454': 'MWI','458': 'MYS','462': 'MDV','466': 'MLI','470': 'MLT','474': 'MTQ','478': 'MRT','480': 'MUS','484': 'MEX','492': 'MCO','496': 'MNG','499': 'MNE','500': 'MSR','504': 'MAR','508': 'MOZ','512': 'OMN','516': 'NAM','520': 'NRU','524': 'NPL','528': 'NLD','531': 'CUW','534': 'NZL','540': 'NCL','548': 'VUT','554': 'NZL','558': 'NIC','562': 'NER','566': 'NGA','570': 'NIU','574': 'NFK','578': 'NOR','580': 'MNP','583': 'FSM','584': 'MHL','585': 'PLW','586': 'PAK','591': 'PAN','598': 'PNG','600': 'PRY','604': 'PER','608': 'PHL','612': 'PCN','616': 'POL','620': 'PRT','624': 'GNB','626': 'TLS','630': 'PRI','634': 'QAT','638': 'REU','642': 'ROU','643': 'RUS','646': 'RWA','652': 'BLM','654': 'SHN','659': 'KNA','660': 'AIA','662': 'LCA','663': 'MAF','666': 'SPM','670': 'VCT','674': 'SMR','678': 'STP','682': 'SAU','686': 'SEN','688': 'SRB','690': 'SYC','694': 'SLE','702': 'SGP','703': 'SVK','704': 'VNM','705': 'SVN','706': 'SOM','710': 'ZAF','716': 'ZWE','724': 'ESP','728': 'SSD','729': 'SDN','732': 'ESH','740': 'SUR','744': 'SJM','748': 'SWZ','752': 'SWE','756': 'CHE','760': 'SYR','762': 'TJK','764': 'THA','768': 'TGO','772': 'TKL','776': 'TON','780': 'TTO','784': 'ARE','788': 'TUN','792': 'TUR','795': 'TKM','796': 'TCA','798': 'TUV','800': 'UGA','804': 'UKR','807': 'MKD','818': 'EGY','826': 'GBR','834': 'TZA','840': 'USA','850': 'VIR','854': 'BFA','858': 'URY','860': 'UZB','862': 'VEN','876': 'WLF','882': 'WSM','887': 'YEM','894': 'ZMB'
        };
        return idMap[id] || null;
      }

      function getStatusColor(status) {
        if (status === 'full') return '#22c55e';
        if (status === 'partial') return '#eab308';
        if (status === 'none') return '#ef4444';
        return '#334155';
      }

      function updateSidebar(data, iso3) {
        sidebarPlaceholder.style.display = 'none';
        sidebarContent.style.display = 'flex';
        const rateClass = data.status === 'full' ? 'rate-green' : data.status === 'partial' ? 'rate-yellow' : 'rate-red';
        const statusLabel = data.status === 'full' ? 'Full Treaty' : data.status === 'partial' ? 'Partial / Limited' : 'No Treaty';
        const iso2 = iso3ToIso2[iso3] || "un";
        sidebarContent.innerHTML = `
          <div class="country-header">
            <img src="https://flagcdn.com/32x24/${iso2}.png" style="width:32px;height:24px;border-radius:3px;" alt="flag">
            <span class="country-name-sidebar">${data.name}</span>
          </div>
          <div class="info-row">
            <span class="info-label">Withholding Rate</span>
            <span class="info-value ${rateClass}">${data.rate}</span>
          </div>
          <div class="info-row">
            <span class="info-label">Treaty Status</span>
            <span class="info-value">${statusLabel}</span>
          </div>
          <div class="info-row">
            <span class="info-label">Estate Tax Exposure</span>
            <span class="badge ${data.estateTax === 'No' ? 'yes' : 'no'}">${data.estateTax}</span>
          </div>
          <div class="info-row">
            <span class="info-label">W-8BEN Required</span>
            <span class="badge ${data.w8ben === 'Yes' ? 'yes' : 'no'}">${data.w8ben}</span>
          </div>
          <a href="${data.guide}" class="btn-guide">Read Full Guide ?</a>
        `;
      }

      const worldUrl = 'https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json';
      d3.json(worldUrl).then(function(world) {
        const countries = topojson.feature(world, world.objects.countries).features;
        svg.selectAll('path')
          .data(countries)
          .enter()
          .append('path')
          .attr('class', 'country-path')
          .attr('d', path)
          .attr('id', d => 'country-' + d.id)
          .style('fill', function(d) {
            const iso = getISO3(d.id);
            const data = treatyData[iso];
            return getStatusColor(data ? data.status : null);
          })
          .on('mouseover', function(event, d) {
            const iso = getISO3(d.id);
            const data = treatyData[iso];
            const name = data ? data.name : 'No data';
            tooltip.style('opacity', 1).text(name);
            if (selectedCountryCode !== iso) {
              d3.select(this).style('filter', 'brightness(1.3)');
            }
          })
          .on('mousemove', function(event) {
            const rect = mapWrapper.getBoundingClientRect();
            tooltip.style('left', (event.clientX - rect.left + 14) + 'px').style('top', (event.clientY - rect.top - 30) + 'px');
          })
          .on('mouseout', function(event, d) {
            tooltip.style('opacity', 0);
            const iso = getISO3(d.id);
            if (selectedCountryCode !== iso) {
              d3.select(this).style('filter', null);
            }
          })
          .on('click', function(event, d) {
            const iso = getISO3(d.id);
            const data = treatyData[iso];
            if (!data) return;
            svg.selectAll('.country-path').classed('selected', false).style('filter', null);
            d3.select(this).classed('selected', true).style('filter', 'brightness(1.4)');
            selectedCountryCode = iso;
            updateSidebar(data, iso);
          });
      }).catch(function(err) {
        console.error('Failed to load map data:', err);
        mapWrapper.innerHTML += '<p style="text-align:center;color:#ef4444;padding:20px;">Failed to load map. Please check your internet connection and try again.</p>';
      });
    })();
  </script>
</BaseLayout>

