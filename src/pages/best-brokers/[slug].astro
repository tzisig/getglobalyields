---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import FinancialDisclaimer from '../../components/FinancialDisclaimer.astro';
import AuthorBio from '../../components/AuthorBio.astro';

export async function getStaticPaths() {
  const posts = await getCollection('best-brokers').catch(() => []);
  return posts.filter(post => !post.data.draft).map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
if (!post) return Astro.redirect('/404');
const { Content } = await render(post);

const isReview = post.data.rating !== undefined;
const maxRating = 5;
const ratingFloor = isReview ? Math.floor(post.data.rating!) : 0;
const pros = post.data.pros ?? [];
const cons = post.data.cons ?? [];
---

<BaseLayout title={`${post.data.title} — Get Global Yields`} description={post.data.description} image={post.data.heroImage}>
  <article class="py-16 lg:py-24 bg-primary-900 border-b border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
        <div class="lg:col-span-2">
          <AffiliateDisclaimer />

          <header class="mb-8">
            <span class="inline-block bg-accent-500 text-primary-900 text-xs font-bold px-3 py-1 rounded uppercase tracking-wider shadow-sm mb-4">
              {isReview ? 'Review' : 'Best Brokers'}
            </span>
            <h1 class="text-4xl md:text-5xl font-bold text-slate-100 tracking-tight mb-4">{post.data.title}</h1>

            {isReview && (
              <div class="flex flex-wrap items-center gap-4 mb-8">
                <div class="flex items-center text-accent-500 bg-primary-800 px-4 py-2 rounded-full border border-primary-700">
                  <span class="font-bold mr-2 text-slate-100">{post.data.rating!.toFixed(1)} / 5</span>
                  <div class="flex">
                    {Array.from({ length: maxRating }).map((_, i) => (
                      <svg class={`w-5 h-5 ${i < ratingFloor ? 'text-accent-500' : 'text-primary-600'}`} fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                </div>
                <p class="text-slate-400 text-sm border-l border-primary-700 pl-4 py-1">
                  By <span class="font-semibold text-slate-300">{post.data.author}</span><br />
                  Updated {post.data.updatedDate ? post.data.updatedDate.toLocaleDateString() : post.data.pubDate.toLocaleDateString()}
                </p>
              </div>
            )}

            {!isReview && (
              <div class="flex items-center text-slate-400 text-sm space-x-4 mb-8">
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span>&bull;</span>
                <span>By {post.data.author}</span>
              </div>
            )}
          </header>

          <!-- Ad Top -->
          <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
            <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
          </div>

          {post.data.heroImage && (
            <img src={post.data.heroImage} alt={post.data.title} class="w-full h-auto rounded-xl mb-12 shadow-2xl border border-primary-700" />
          )}

          {isReview && pros.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
              <div class="bg-primary-800 rounded-xl p-6 border border-primary-700 border-t-4 border-t-green-500 shadow-lg">
                <h3 class="text-xl font-bold flex items-center text-slate-100 mb-4">
                  <svg class="w-6 h-6 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
                  </svg>
                  Pros
                </h3>
                <ul class="space-y-3">
                  {pros.map(pro => (
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-green-500 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                      <span class="text-slate-300">{pro}</span>
                    </li>
                  ))}
                </ul>
              </div>
              <div class="bg-primary-800 rounded-xl p-6 border border-primary-700 border-t-4 border-t-red-500 shadow-lg">
                <h3 class="text-xl font-bold flex items-center text-slate-100 mb-4">
                  <svg class="w-6 h-6 text-red-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018a2 2 0 01.485.06l3.76.94m-7 10v5a2 2 0 002 2h.096c.5 0 .905-.405.905-.904 0-.714.211-1.412.608-2.006L17 13V4m-7 10h2m5-10h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5" />
                  </svg>
                  Cons
                </h3>
                <ul class="space-y-3">
                  {cons.map(con => (
                    <li class="flex items-start">
                      <svg class="w-5 h-5 text-red-500 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                      <span class="text-slate-300">{con}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          )}

          <!-- Ad Middle -->
          <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
            <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
          </div>

          <div class="prose prose-invert prose-lg prose-a:text-accent-500 hover:prose-a:text-accent-400 max-w-none mb-16">
            <Content />
          </div>

          <!-- Ad Bottom -->
          <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
            <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
          </div>

          {post.data.affiliateLink && (
            <div class="bg-primary-800 border-t-4 border-accent-500 rounded-2xl p-8 sm:p-10 text-center shadow-2xl border border-primary-700 mt-12 mb-8">
              <h3 class="text-2xl sm:text-3xl font-bold text-slate-100 mb-4">Ready to start with {post.data.productName}?</h3>
              <a href={post.data.affiliateLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-lg text-primary-900 bg-accent-500 hover:bg-accent-400 transition-all shadow-lg transform hover:-translate-y-1">
                Visit {post.data.productName} Securely
                <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
              <p class="text-xs text-slate-500 mt-6 max-w-xl mx-auto">* Affiliate Disclosure: We may receive a small commission if you sign up through this link.</p>
            </div>
          )}

          <FinancialDisclaimer />
          <AuthorBio name={post.data.author} />
        </div>

        <div class="hidden lg:block lg:col-span-1">
          <Sidebar />
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
