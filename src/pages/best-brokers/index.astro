---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { BEST_BROKERS_HUB } from '../../data/bestBrokersHub';
import { getCollection } from 'astro:content';
import ThemeHeroImage from '../../components/ThemeHeroImage.astro';

const allBrokerPosts = await getCollection('best-brokers');

const reviews = BEST_BROKERS_HUB.filter(e => e.kind === 'review');
const guides  = BEST_BROKERS_HUB.filter(e => e.kind === 'guide');

const topPickSlugs = [
  'interactive-brokers-review-2026-the-best-broker-for-international-investors',
  'etoro-review-2026',
  'saxo-bank-review-2026'
];

const otherReviews = allBrokerPosts.filter(post => {
  const slug = post.slug || post.id.replace(/\.md$/, '');
  return !topPickSlugs.includes(slug);
});

console.log(`[best-brokers] Total entries found: ${allBrokerPosts.length}`);
console.log(`[best-brokers] Entries after excluding Top Picks: ${otherReviews.length}`);

const brokerMeta: Record<string, { initials: string; tagline: string; tags: string[]; bestFor: string }> = {
  'interactive-brokers-review-2026-the-best-broker-for-international-investors': {
    initials: 'IB',
    bestFor: 'Best Overall',
    tagline: 'Ultra-low fees, 150+ global markets, best-in-class FX conversion. The long-term choice for serious international investors.',
    tags: ['Lowest Fees', 'US Options', 'FX Optimized', '200+ Countries'],
  },
  'etoro-review-2026': {
    initials: 'eT',
    bestFor: 'Best for Beginners',
    tagline: 'Social and copy trading, zero-commission stocks. Available in 140+ countries with a low $50 minimum deposit.',
    tags: ['Copy Trading', 'Zero Commission', '140+ Countries'],
  },
  'saxo-bank-review-2026': {
    initials: 'SB',
    bestFor: 'Best for High Net Worth',
    tagline: 'Institutional research, 70,000+ instruments, multi-currency accounts. Fees drop sharply at Platinum ($200k+) and VIP ($1M+).',
    tags: ['Pro Tools', 'Full Market Access', 'Multi-Currency'],
  },
};

const guideIcons: Record<string, string> = {
  'how-to-open-a-us-brokerage-account-as-a-non-resident-2026-guide': '📋',
  'best-brokers-international-investors-2026': '🌍',
};
---

<BaseLayout
  title="Best Brokers for International Investors (2026) | Get Global Yields"
  description="Compare the best brokers for non-US investors. In-depth reviews of Interactive Brokers, eToro, and Saxo Bank plus guides for opening a US brokerage account from abroad."
>

  <!-- HERO -->
  <div class="bg-gradient-to-b from-primary-800 to-primary-900 border-b border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20 max-w-3xl text-center">
      <span class="inline-block mb-5 rounded-full border border-accent-500/30 bg-accent-500/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-accent-500">
        Updated 2026 · Non-US Investors
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-5 tracking-tight leading-tight">
        Best Brokers for International Investors
      </h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto mb-8">
        In-depth broker reviews, step-by-step guides, and comparisons - everything a non-US investor needs to open and manage a US brokerage account.
      </p>
    </div>
  </div>

  <div class="bg-primary-900">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-14 max-w-6xl space-y-16">

      <!-- Editor's Top Picks -->
      {reviews.length > 0 && (
        <section id="reviews">
          <h2 class="text-2xl font-bold text-slate-100 mb-2">Editor's Top Picks</h2>
          <p class="text-slate-400 mb-8">Detailed, unbiased reviews of the top brokers available to international investors.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {reviews.map((entry) => {
              const meta = brokerMeta[entry.slug];
              const post = allBrokerPosts.find(p => p.slug === entry.slug || p.id === entry.slug || p.id === entry.contentId || p.id === entry.slug + '.md' || p.id === entry.contentId + '.md');
              const heroImage = post?.data?.heroImage || '';
              const heroImageLight = heroImage?.replace('/images/blog/', '/images/blog/light/');
              const altText = post?.data?.title || entry.title;
              return (
                <a
                  href={`/best-brokers/${entry.slug}/`}
                  class="group flex flex-col bg-primary-800 border border-primary-700 rounded-2xl p-6 hover:border-accent-500/50 hover:shadow-lg hover:shadow-accent-500/10 transition-all duration-200"
                >
                  <div class="w-full h-48 bg-primary-700/50 rounded-xl mb-6 overflow-hidden shrink-0">
                    <ThemeHeroImage
                      darkSrc={heroImage}
                      lightSrc={heroImageLight}
                      alt={altText}
                      width={post?.data?.heroImageWidth ?? 840}
                      height={post?.data?.heroImageHeight ?? 560}
                      class="w-full h-full object-cover"
                      loading="lazy"
                      fetchpriority={null}
                      decoding="async"
                    />
                  </div>
                  <div class="flex items-center gap-4 mb-4">
                    <div class="w-12 h-12 rounded-xl bg-accent-500/10 border border-accent-500/20 flex items-center justify-center text-accent-500 font-bold text-lg shrink-0">
                      {meta?.initials ?? entry.title.charAt(0)}
                    </div>
                    <div>
                      {meta?.bestFor && (
                        <span class="inline-block text-xs font-semibold text-accent-500 uppercase tracking-wide mb-1">{meta.bestFor}</span>
                      )}
                      <h3 class="text-base font-bold text-slate-100 leading-tight group-hover:text-accent-500 transition-colors">
                        {entry.title}
                      </h3>
                    </div>
                  </div>
                  {meta?.tagline && (
                    <p class="text-slate-400 text-sm mb-4 flex-1">{meta.tagline}</p>
                  )}
                  {meta?.tags && (
                    <div class="flex flex-wrap gap-2 mt-auto">
                      {meta.tags.map(tag => (
                        <span class="text-xs bg-primary-700 text-slate-300 px-2.5 py-1 rounded-full">{tag}</span>
                      ))}
                    </div>
                  )}
                  <div class="mt-4 text-sm font-semibold text-accent-500 flex items-center gap-1">
                    Read Review
                    <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <!-- ALL BROKER REVIEWS -->
      <section id="all-reviews">
        <h2 class="text-2xl font-bold text-slate-100 mb-2">All Broker Reviews</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {otherReviews.map((post) => {
            const heroImage = post.data?.heroImage || '';
            const heroImageLight = heroImage?.replace('/images/blog/', '/images/blog/light/');
            const title = post.data?.title || 'Review';
            const description = post.data?.description || '';
            const tags = post.data?.tags || [];
            const slug = post.slug || post.id.replace(/\.md$/, '');
            return (
            <a
              href={`/best-brokers/${slug}/`}
              class="group flex flex-col bg-primary-800 border border-primary-700 rounded-2xl p-5 hover:border-accent-500/50 hover:shadow-lg hover:shadow-accent-500/10 transition-all duration-200"
            >
              <div class="w-full h-32 bg-primary-700/50 rounded-xl mb-4 overflow-hidden shrink-0">
                <ThemeHeroImage
                  darkSrc={heroImage}
                  lightSrc={heroImageLight}
                  alt={title}
                  width={post.data.heroImageWidth ?? 840}
                  height={post.data.heroImageHeight ?? 560}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  fetchpriority={null}
                  decoding="async"
                />
              </div>
              <h3 class="text-base font-bold text-slate-100 leading-tight group-hover:text-accent-500 transition-colors mb-2">
                {title}
              </h3>
              <p class="text-slate-400 text-sm mb-4 flex-1">{description}</p>
              {tags && tags.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-auto mb-4">
                  {tags.slice(0, 3).map((tag: string) => (
                    <span class="text-xs bg-primary-700 text-slate-300 px-2.5 py-1 rounded-full">{tag}</span>
                  ))}
                </div>
              )}
              <div class="text-sm font-semibold text-accent-500 flex items-center gap-1 mt-auto">
                Read Review
                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          )})}
        </div>
      </section>

      <!-- GUIDES -->
      {guides.length > 0 && (
        <section id="guides">
          <h2 class="text-2xl font-bold text-slate-100 mb-2">Guides</h2>
          <p class="text-slate-400 mb-8">Step-by-step guides for navigating US markets as a non-resident investor.</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {guides.map((entry) => {
              const icon = guideIcons[entry.slug] ?? '📖';
              return (
                <a
                  href={`/best-brokers/${entry.slug}/`}
                  class="group flex items-start gap-5 bg-primary-800 border border-primary-700 rounded-2xl p-6 hover:border-accent-500/50 hover:shadow-lg hover:shadow-accent-500/10 transition-all duration-200"
                >
                  <div class="text-3xl shrink-0">{icon}</div>
                  <div>
                    <h3 class="text-base font-bold text-slate-100 group-hover:text-accent-500 transition-colors mb-2 leading-snug">
                      {entry.title}
                    </h3>
                    <span class="text-sm font-semibold text-accent-500 flex items-center gap-1">
                      Read Guide
                      <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}



    </div>
  </div>

  <!-- Financial Disclaimer -->
  <div class="bg-primary-900 border-t border-primary-700 py-6">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <p class="text-xs text-slate-500 text-center leading-relaxed">
        <strong class="text-slate-400">Financial Disclaimer:</strong> This content is for educational purposes only and is not financial advice. Investing involves risk. <a href="/disclaimer/" class="hover:text-accent-500 underline">Read full disclaimer</a>.
      </p>
    </div>
  </div>
</BaseLayout>
