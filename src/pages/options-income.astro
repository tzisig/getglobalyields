---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Options Income strategies"
  description="Learn how to generate high-yield passive income by selling options contracts globally."
>
  <div class="bg-primary-900 py-16 lg:py-24 border-b border-primary-700 relative overflow-hidden">
    <div class="container relative mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-slate-100 mb-6">
        Generate <span class="text-accent-500">Options Income</span>
      </h1>
      <p class="text-xl text-slate-300 leading-relaxed max-w-2xl mx-auto">
        Yield generation strategies using basic options mechanics to boost your portfolio returns consistently over time.
      </p>
    </div>
  </div>

  <section class="py-24 bg-primary-800 min-h-[50vh]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <!-- Coming Soon Card -->
      <div class="bg-primary-900 rounded-2xl border-2 border-primary-700 border-dashed p-12 lg:p-16">
        <div class="w-24 h-24 mx-auto bg-primary-800 rounded-full flex items-center justify-center mb-6 text-accent-500 shadow-inner">
          <svg class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
          </svg>
        </div>
        <h2 class="text-3xl font-bold text-slate-100 mb-4">Content Coming Soon</h2>
        <p class="text-lg text-slate-400 max-w-lg mx-auto">
          We are currently crafting in-depth, high-value guides on generating options income designed for our global community. Check back soon!
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
