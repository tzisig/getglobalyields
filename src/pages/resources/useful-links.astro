---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
import FinancialDisclaimer from '../../components/FinancialDisclaimer.astro';

const linkCategories = [
  {
    title: 'Brokers',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
    links: [
      { name: 'Interactive Brokers', url: 'https://ibkr.com', desc: 'ibkr.com' },
      { name: 'tastytrade', url: 'https://tastytrade.com', desc: 'tastytrade.com' },
      { name: 'Firstrade', url: 'https://firstrade.com', desc: 'firstrade.com' }
    ]
  },
  {
    title: 'Options Tools',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>',
    links: [
      { name: 'Market Chameleon', url: 'https://marketchameleon.com', desc: 'Free IV Rank data (marketchameleon.com)' },
      { name: 'tastytrade Options Education', url: 'https://tastytrade.com/learn', desc: 'tastytrade.com/learn' }
    ]
  },
  {
    title: 'Tax & Compliance',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>',
    links: [
      { name: 'IRS W-8BEN Instructions', url: 'https://www.irs.gov/forms-pubs/about-form-w-8-ben', desc: 'irs.gov' },
      { name: 'IRS Tax Treaty Countries', url: 'https://www.irs.gov/businesses/international-businesses/united-states-income-tax-treaties-a-to-z', desc: 'irs.gov' },
      { name: 'Israel Tax Authority', url: 'https://www.gov.il/en/departments/israel_tax_authority/govil-landing-page', desc: 'gov.il' }
    ]
  },
  {
    title: 'Market Data',
    icon: '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>',
    links: [
      { name: 'Yahoo Finance', url: 'https://finance.yahoo.com', desc: 'finance.yahoo.com' },
      { name: 'ETF Database', url: 'https://etfdb.com', desc: 'etfdb.com' },
      { name: 'Stock Analysis', url: 'https://stockanalysis.com', desc: 'stockanalysis.com' }
    ]
  }
];
---

<BaseLayout 
  title="Useful Links & Resources | Get Global Yields" 
  description="A curated directory of the best brokers, options tools, market data, and tax compliance resources for international investors."
>
  <div class="container mx-auto px-4 py-12 sm:px-6 lg:px-8 max-w-6xl">
    <div class="mb-12 text-center">
      <h1 class="text-4xl font-bold text-slate-100 mb-4">Useful <span class="text-accent-500">Links</span></h1>
      <p class="text-lg text-slate-400 max-w-2xl mx-auto">
        A curated collection of top-tier resources, tools, and regulatory sites for global investors.
      </p>
    </div>

    <!-- Layout: Main content + Sidebar -->
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Main Content — single column cards -->
      <main class="flex-grow">
        <div class="grid grid-cols-1 gap-6">
          {linkCategories.map((category) => (
            <div class="bg-primary-800 rounded-2xl border border-primary-700 overflow-hidden shadow-lg">
              <div class="bg-primary-900 border-b border-primary-700 px-6 py-4 flex items-center gap-3">
                <div class="text-accent-500" set:html={category.icon} />
                <h2 class="text-xl font-bold text-slate-100">{category.title}</h2>
              </div>
              
              <div class="p-6">
                <ul class="space-y-4">
                  {category.links.map((link) => (
                    <li>
                      <a 
                        href={link.url} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="group block p-4 bg-primary-900 rounded-xl border border-primary-700 hover:border-accent-500 transition-all hover:shadow-md hover:-translate-y-0.5"
                      >
                        <div class="flex items-center justify-between">
                          <div>
                            <h3 class="text-slate-100 font-bold group-hover:text-accent-500 transition-colors">{link.name}</h3>
                            <p class="text-slate-400 text-sm mt-1">{link.desc}</p>
                          </div>
                          <svg class="w-5 h-5 text-slate-500 group-hover:text-accent-500 transition-colors transform group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                          </svg>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 p-4 border-t border-primary-700 text-center">
          <p class="text-slate-400 text-sm">
            External links are provided for informational purposes. We are not responsible for third-party content.
          </p>
        </div>
      </main>

      <!-- Right Sidebar -->
      <div class="hidden lg:block w-full lg:w-[320px] flex-shrink-0">
        <div class="sticky top-24">
          <Sidebar />
        </div>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
    <FinancialDisclaimer />
  </div>
</BaseLayout>
