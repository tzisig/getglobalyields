---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';
---

<BaseLayout 
  title="Resources | Get Global Yields" 
  description="Expert tools, glossaries, and useful links to empower your global investment journey."
>
  <div class="py-12 lg:py-16 bg-primary-900 border-b border-primary-700">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-bold text-slate-100 mb-4">Investment <span class="text-accent-500">Resources</span></h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">
          Everything you need to navigate international markets, understand complex financial concepts, and calculate your potential returns.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <!-- Glossary Card -->
        <a href="/resources/glossary/" class="group flex flex-col items-center p-8 bg-primary-800 rounded-2xl border border-primary-700 hover:border-accent-500 transition-all shadow-lg hover:shadow-accent-500/10 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-accent-500/0 to-accent-500/5 group-hover:to-accent-500/10 transition-colors"></div>
          <div class="w-16 h-16 bg-primary-900 rounded-full flex items-center justify-center mb-6 text-accent-500 border border-primary-700 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-100 mb-3 group-hover:text-accent-500 transition-colors relative z-10">Glossary</h2>
          <p class="text-slate-400 relative z-10">Master financial jargon with our comprehensive dictionary of trading and macro-economic terms.</p>
        </a>

        <!-- Calculators Card -->
        <a href="/resources/calculators/" class="group flex flex-col items-center p-8 bg-primary-800 rounded-2xl border border-primary-700 hover:border-accent-500 transition-all shadow-lg hover:shadow-accent-500/10 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-blue-500/0 to-blue-500/5 group-hover:to-blue-500/10 transition-colors"></div>
          <div class="w-16 h-16 bg-primary-900 rounded-full flex items-center justify-center mb-6 text-blue-400 border border-primary-700 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-100 mb-3 group-hover:text-blue-400 transition-colors relative z-10">Calculators</h2>
          <p class="text-slate-400 relative z-10">Evaluate potential returns, withholding tax drag, and compound growth scenarios.</p>
        </a>

        <!-- Useful Links Card -->
        <a href="/resources/useful-links/" class="group flex flex-col items-center p-8 bg-primary-800 rounded-2xl border border-primary-700 hover:border-accent-500 transition-all shadow-lg hover:shadow-accent-500/10 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-green-500/0 to-green-500/5 group-hover:to-green-500/10 transition-colors"></div>
          <div class="w-16 h-16 bg-primary-900 rounded-full flex items-center justify-center mb-6 text-green-400 border border-primary-700 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-100 mb-3 group-hover:text-green-400 transition-colors relative z-10">Useful Links</h2>
          <p class="text-slate-400 relative z-10">Curated external resources, tax authority pages, and critical investment tools.</p>
        </a>

        <!-- Broker Finder Card -->
        <a href="/resources/broker-finder/" class="group flex flex-col items-center p-8 bg-primary-800 rounded-2xl border border-primary-700 hover:border-accent-500 transition-all shadow-lg hover:shadow-accent-500/10 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-purple-500/0 to-purple-500/5 group-hover:to-purple-500/10 transition-colors"></div>
          <div class="w-16 h-16 bg-primary-900 rounded-full flex items-center justify-center mb-6 text-purple-400 border border-primary-700 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 21a9 9 0 100-18 9 9 0 000 18zm0 0c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3s-4.5 4.03-4.5 9 2.015 9 4.5 9zM3.6 9h16.8M3.6 15h16.8" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-100 mb-3 group-hover:text-purple-400 transition-colors relative z-10">Broker Finder</h2>
          <p class="text-slate-400 relative z-10">Find brokers that accept investors in your country and compare available platforms side by side.</p>
        </a>

        <!-- Broker Calculator Card -->
        <a href="/resources/broker-calculator/" class="group flex flex-col items-center p-8 bg-primary-800 rounded-2xl border border-primary-700 hover:border-accent-500 transition-all shadow-lg hover:shadow-accent-500/10 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-red-500/0 to-red-500/5 group-hover:to-red-500/10 transition-colors"></div>
          <div class="w-16 h-16 bg-primary-900 rounded-full flex items-center justify-center mb-6 text-red-400 border border-primary-700 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-100 mb-3 group-hover:text-red-400 transition-colors relative z-10">Broker Calculator</h2>
          <p class="text-slate-400 relative z-10">Compare broker fee rates and estimate how much switching providers could save over time.</p>
        </a>

        <!-- Tax Map Card -->
        <a href="/resources/tax-map/" class="group flex flex-col items-center p-8 bg-primary-800 rounded-2xl border border-primary-700 hover:border-accent-500 transition-all shadow-lg hover:shadow-accent-500/10 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-cyan-500/0 to-cyan-500/5 group-hover:to-cyan-500/10 transition-colors"></div>
          <div class="w-16 h-16 bg-primary-900 rounded-full flex items-center justify-center mb-6 text-cyan-400 border border-primary-700 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-100 mb-3 group-hover:text-cyan-400 transition-colors relative z-10">Tax Map</h2>
          <p class="text-slate-400 relative z-10">Explore US tax treaty status, withholding rates, and W-8BEN requirements by country.</p>
        </a>

        <!-- Investor Profiles Card -->
        <a href="/resources/investor-profiles/" class="group flex flex-col items-center p-8 bg-primary-800 rounded-2xl border border-primary-700 hover:border-accent-500 transition-all shadow-lg hover:shadow-accent-500/10 text-center relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/0 to-orange-500/5 group-hover:to-orange-500/10 transition-colors"></div>
          <div class="w-16 h-16 bg-primary-900 rounded-full flex items-center justify-center mb-6 text-orange-400 border border-primary-700 group-hover:scale-110 transition-transform">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-slate-100 mb-3 group-hover:text-orange-400 transition-colors relative z-10">Investor Profiles</h2>
          <p class="text-slate-400 relative z-10">See how international investors from different countries access US markets and build portfolios.</p>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
