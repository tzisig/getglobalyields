---
export interface Props {
  name?: string;
}

const { name = 'Tzion' } = Astro.props;
---

<div class="mt-16 bg-primary-800 rounded-2xl p-6 sm:p-8 border border-primary-700 shadow-xl flex flex-col sm:flex-row items-center sm:items-start gap-6 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-br from-accent-500/5 to-transparent pointer-events-none"></div>
  <div class="shrink-0 relative z-10">
    <div class="w-24 h-24 rounded-full bg-primary-900 border-2 border-accent-500 overflow-hidden flex items-center justify-center text-accent-500 shadow-lg shadow-accent-500/20">
      <!-- Using DiceBear API for a reliable, professional placeholder avatar -->
      <img 
        src="/theauthor.png" 
        alt={name} 
        class="w-full h-full object-cover" 
      />
    </div>
  </div>
  <div class="text-center sm:text-left relative z-10 flex-1">
    <h3 class="text-xl font-bold text-slate-100 mb-2">Written by {name}</h3>
    <p class="text-slate-300 text-sm leading-relaxed">
      Leveraging over 20 years of expertise as a software developer, I apply a rigorous analytical and systems-driven mindset to the world of high-yield investing. I specialize in leveraged ETFs (TQQQ) and advanced options strategies, focusing on generating consistent returns through data-driven risk management and technical market analysis. As the founder of Get Global Yields, I am dedicated to helping expats and international investors navigate the US markets with precision, turning complex financial instruments into sustainable global wealth.
    </p>
  </div>
</div>
