---
import { getEntry, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import Sidebar from '../../components/Sidebar.astro';
import AffiliateDisclaimer from '../../components/AffiliateDisclaimer.astro';
import { BEST_BROKERS_HUB } from '../../data/bestBrokersHub';

export async function getStaticPaths() {
  return BEST_BROKERS_HUB.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;

type GuidePost = CollectionEntry<'guides'>;
type ReviewPost = CollectionEntry<'reviews'>;

let guidePost: GuidePost | undefined;
let reviewPost: ReviewPost | undefined;
let ArticleContent: Awaited<ReturnType<typeof render>>['Content'] | undefined = undefined;
let ratingFloor = 0;

if (entry.kind === 'guide') {
  const post = await getEntry('guides', entry.contentId);
  if (!post) return Astro.redirect('/404');
  guidePost = post;
  const rendered = await render(post);
  ArticleContent = rendered.Content;
} else if (entry.kind === 'review') {
  const post = await getEntry('reviews', entry.contentId);
  if (!post) return Astro.redirect('/404');
  reviewPost = post;
  ratingFloor = Math.floor(post.data.rating);
  const rendered = await render(post);
  ArticleContent = rendered.Content;
}

const maxRating = 5;
---

{entry.kind === 'coming' && (
  <BaseLayout title={`${entry.title} - Coming Soon | Get Global Yields`} description={entry.teaser ?? 'Coming soon on Get Global Yields.'}>
    <div class="py-16 lg:py-24 bg-primary-900 border-b border-primary-700">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-wider text-accent-500 mb-3">Best Brokers</p>
        <h1 class="text-3xl md:text-4xl font-extrabold text-slate-100 mb-4">{entry.title}</h1>
        <p class="text-lg text-slate-400 mb-8">{entry.teaser ?? 'We are preparing this article. Check back soon.'}</p>
        <a href="/best-brokers" class="inline-flex items-center justify-center px-8 py-3 text-base font-bold rounded-md text-primary-900 bg-accent-500 hover:bg-accent-400 transition-colors">
          All Best Brokers articles
        </a>
      </div>
    </div>
  </BaseLayout>
)}

{entry.kind === 'guide' && guidePost && ArticleContent && (
  <BaseLayout title={`${guidePost.data.title} - Get Global Yields`} description={guidePost.data.description} image={guidePost.data.heroImage}>
    <article class="py-16 lg:py-24 bg-primary-900 border-b border-primary-700">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
          <div class="lg:col-span-2">
            <AffiliateDisclaimer />

            <header class="mb-8 text-center">
              {guidePost.data.categories && guidePost.data.categories.length > 0 && (
                <span class="inline-block bg-accent-500 text-primary-900 text-xs font-bold px-3 py-1 rounded uppercase tracking-wider shadow-sm mb-4">
                  {guidePost.data.categories[0]}
                </span>
              )}
              <h1 class="text-4xl md:text-5xl font-extrabold text-slate-100 tracking-tight mb-4">{guidePost.data.title}</h1>
              <div class="flex items-center justify-center text-slate-400 text-sm space-x-4">
                <time datetime={guidePost.data.pubDate.toISOString()}>
                  {guidePost.data.pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span>&bull;</span>
                <span>By {guidePost.data.author}</span>
              </div>
            </header>

            <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
              <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
            </div>

            {guidePost.data.heroImage && (
              <img src={guidePost.data.heroImage} alt={guidePost.data.title} class="w-full h-auto rounded-xl mb-12 shadow-2xl border border-primary-700" />
            )}

            <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
              <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
            </div>

            <div class="prose prose-invert prose-lg prose-a:text-accent-500 hover:prose-a:text-accent-400 max-w-none">
              <ArticleContent />
            </div>

            <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
              <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
            </div>

            <AuthorBio name={guidePost.data.author} />
          </div>

          <div class="hidden lg:block lg:col-span-1">
            <Sidebar />
          </div>
        </div>
      </div>
    </article>
  </BaseLayout>
)}

{entry.kind === 'review' && reviewPost && ArticleContent && (
    <BaseLayout title={`${reviewPost.data.title} - Get Global Yields`} description={reviewPost.data.description} image={reviewPost.data.heroImage}>
      <article class="py-16 lg:py-24 bg-primary-900 border-b border-primary-700">
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
            <div class="lg:col-span-2">
              <AffiliateDisclaimer />

              <header class="mb-8">
                <span class="inline-block bg-accent-500 text-primary-900 text-xs font-bold px-3 py-1 rounded uppercase tracking-wider shadow-sm mb-4">
                  Review
                </span>
                <h1 class="text-4xl md:text-5xl font-extrabold text-slate-100 tracking-tight mb-4">{reviewPost.data.title}</h1>

                <div class="flex flex-wrap items-center gap-4 mb-8">
                  <div class="flex items-center text-accent-500 bg-primary-800 px-4 py-2 rounded-full border border-primary-700">
                    <span class="font-bold mr-2 text-slate-100">{reviewPost.data.rating.toFixed(1)} / 5</span>
                    <div class="flex">
                      {Array.from({ length: maxRating }).map((_, i) => (
                        <svg class={`w-5 h-5 ${i < ratingFloor ? 'text-accent-500' : 'text-primary-600'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                  </div>
                  <p class="text-slate-400 text-sm border-l border-primary-700 pl-4 py-1">
                    By <span class="font-semibold text-slate-300">{reviewPost.data.author}</span><br />
                    Updated {reviewPost.data.updatedDate ? reviewPost.data.updatedDate.toLocaleDateString() : reviewPost.data.pubDate.toLocaleDateString()}
                  </p>
                </div>

                <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
                  <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
                </div>

                {reviewPost.data.heroImage && (
                  <img src={reviewPost.data.heroImage} alt={reviewPost.data.productName} class="w-full h-auto rounded-xl mb-12 shadow-2xl border border-primary-700" />
                )}

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12 relative z-10">
                  <div class="bg-primary-800 rounded-xl p-6 border border-primary-700 border-t-4 border-t-green-500 shadow-lg">
                    <h3 class="text-xl font-bold flex items-center text-slate-100 mb-4">
                      <svg class="w-6 h-6 text-green-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
                      </svg>
                      Pros
                    </h3>
                    <ul class="space-y-3">
                      {reviewPost.data.pros.map((pro) => (
                        <li class="flex items-start">
                          <svg class="w-5 h-5 text-green-500 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                          <span class="text-slate-300">{pro}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                  <div class="bg-primary-800 rounded-xl p-6 border border-primary-700 border-t-4 border-t-red-500 shadow-lg">
                    <h3 class="text-xl font-bold flex items-center text-slate-100 mb-4">
                      <svg class="w-6 h-6 text-red-500 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14H5.236a2 2 0 01-1.789-2.894l3.5-7A2 2 0 018.736 3h4.018a2 2 0 01.485.06l3.76.94m-7 10v5a2 2 0 002 2h.096c.5 0 .905-.405.905-.904 0-.714.211-1.412.608-2.006L17 13V4m-7 10h2m5-10h2a2 2 0 012 2v6a2 2 0 01-2 2h-2.5" />
                      </svg>
                      Cons
                    </h3>
                    <ul class="space-y-3">
                      {reviewPost.data.cons.map((con) => (
                        <li class="flex items-start">
                          <svg class="w-5 h-5 text-red-500 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                          <span class="text-slate-300">{con}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </header>

              <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
                <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
              </div>

              <div class="prose prose-invert prose-lg prose-a:text-accent-500 hover:prose-a:text-accent-400 max-w-none mb-16">
                <ArticleContent />
              </div>

              <div class="w-full my-8 bg-primary-800/30 border-2 border-dashed border-primary-700 p-4 flex justify-center items-center text-slate-500 rounded-lg min-h-[100px]">
                <span class="text-xs uppercase tracking-widest font-semibold">Advertisement</span>
              </div>

              {reviewPost.data.affiliateLink && (
                <div class="bg-primary-800 border-t-4 border-accent-500 rounded-2xl p-8 sm:p-10 text-center shadow-2xl border border-primary-700 relative overflow-hidden mt-12 mb-8">
                  <div class="absolute inset-0 bg-gradient-to-br from-accent-500/5 to-transparent pointer-events-none"></div>
                  <h3 class="text-2xl sm:text-3xl font-extrabold text-slate-100 mb-4 relative z-10">Ready to start with {reviewPost.data.productName}?</h3>
                  <p class="text-slate-300 mb-8 max-w-2xl mx-auto relative z-10 text-lg">Take advantage of the benefits and features discussed in our review.</p>
                  <a href={reviewPost.data.affiliateLink} target="_blank" rel="noopener noreferrer" class="relative z-10 inline-flex items-center justify-center px-8 py-4 text-lg font-bold rounded-lg text-primary-900 bg-accent-500 hover:bg-accent-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-primary-900 focus:ring-accent-500 transition-all shadow-[0_0_20px_rgba(255,215,0,0.3)] hover:shadow-[0_0_30px_rgba(255,215,0,0.5)] transform hover:-translate-y-1">
                    Visit {reviewPost.data.productName} Securely
                    <svg class="w-5 h-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                  <p class="text-xs text-slate-500 mt-6 leading-relaxed relative z-10 max-w-xl mx-auto">
                    * Affiliate Disclosure: We may receive a small commission if you sign up through this link. This helps support our independent research and doesn't impact your costs.
                  </p>
                </div>
              )}
            </div>

            <div class="hidden lg:block lg:col-span-1">
              <Sidebar />
            </div>
          </div>
        </div>
      </article>
    </BaseLayout>
)}
