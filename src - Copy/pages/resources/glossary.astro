---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar.astro';

const glossaryTerms = [
  { term: '1042-S', definition: 'IRS form issued to foreign investors showing US-source income and taxes withheld' },
  { term: 'Assignment', definition: 'The obligation to buy (put) or sell (call) shares when an options contract is exercised' },
  { term: 'Cash-Secured Put (CSP)', definition: 'Selling a put option while holding enough cash to buy the shares if assigned' },
  { term: 'Covered Call (CC)', definition: 'Selling a call option on shares you already own' },
  { term: 'Delta', definition: "The rate of change in an option's price relative to a $1 move in the underlying" },
  { term: 'Dollar-Cost Averaging (DCA)', definition: 'Investing a fixed amount at regular intervals regardless of price' },
  { term: 'DTE', definition: 'Days To Expiration, the number of days remaining until an options contract expires' },
  { term: 'Foreign Tax Credit', definition: 'A tax credit for taxes paid to a foreign government, reducing home country tax liability' },
  { term: 'Iron Condor', definition: 'An options strategy selling both an OTM put spread and OTM call spread simultaneously' },
  { term: 'IV Percentile (IVP)', definition: 'The percentage of days in the past year where IV was lower than today' },
  { term: 'IV Rank (IVR)', definition: 'A measure of where current implied volatility sits relative to its 52-week range (0-100)' },
  { term: 'PFIC', definition: 'Passive Foreign Investment Company, a US tax classification relevant to international investors' },
  { term: 'Return of Capital (ROC)', definition: 'A distribution that returns part of your original investment rather than income' },
  { term: 'The 4% Rule', definition: 'A retirement guideline suggesting withdrawing 4% of portfolio value annually' },
  { term: 'The Wheel Strategy', definition: 'A cyclic options income strategy combining cash-secured puts and covered calls' },
  { term: 'Theta Decay', definition: "The daily erosion of an option's time value as expiration approaches" },
  { term: 'TQQQ', definition: 'ProShares UltraPro QQQ, a 3x leveraged ETF tracking the Nasdaq-100' },
  { term: 'VIX', definition: 'CBOE Volatility Index, a real-time measure of S&P 500 implied volatility' },
  { term: 'Volatility Decay', definition: 'The structural drag on leveraged ETF returns caused by daily rebalancing in volatile markets' },
  { term: 'W-8BEN', definition: 'IRS form certifying foreign investor status, required to claim reduced dividend withholding rates' },
];

// Group terms by first letter
const groupedTerms: Record<string, typeof glossaryTerms> = {};
for (const item of glossaryTerms) {
  const letter = item.term[0].toUpperCase();
  if (!groupedTerms[letter]) {
    groupedTerms[letter] = [];
  }
  groupedTerms[letter].push(item);
}

const sortedLetters = Object.keys(groupedTerms).sort();
---

<BaseLayout 
  title="Financial Glossary | Get Global Yields" 
  description="A comprehensive glossary of terms for international investors, options traders, and ETF strategies."
>
  <div class="py-12 lg:py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-bold text-slate-100 mb-4">Financial <span class="text-accent-500">Glossary</span></h1>
        <p class="text-lg text-slate-400 max-w-2xl mx-auto">
          Search for definitions of important investment concepts, tax forms, and options strategies.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 lg:gap-12">
        <div class="lg:col-span-2">
          <!-- Search Input -->
          <div class="relative max-w-xl mb-12">
            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
              <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <input 
              type="text" 
              id="glossary-search" 
              placeholder="Filter terms (e.g., 'IVR', 'Tax')..." 
              class="block w-full pl-11 pr-4 py-4 bg-primary-800 border border-primary-700 rounded-xl text-slate-100 placeholder-slate-500 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent transition-all shadow-lg"
            />
          </div>

          <!-- Glossary List -->
          <div class="space-y-12" id="glossary-container">
            {sortedLetters.map((letter) => (
              <div class="glossary-group" data-letter={letter}>
                <div class="flex items-center mb-6">
                  <h2 class="text-3xl font-bold text-accent-500">{letter}</h2>
                  <div class="ml-4 flex-grow h-px bg-primary-700"></div>
                </div>
                
                <div class="grid gap-4">
                  {groupedTerms[letter].map((item) => (
                    <div class="glossary-term-card bg-primary-800 p-6 rounded-xl border border-primary-700 transition-all hover:border-accent-500 hover:shadow-lg hover:shadow-accent-500/5">
                      <h3 class="text-xl font-bold text-slate-100 mb-2 glossary-term-title">{item.term}</h3>
                      <p class="text-slate-400 leading-relaxed glossary-term-desc">{item.definition}</p>
                    </div>
                  ))}
                </div>
              </div>
            ))}
            
            <!-- Empty State -->
            <div id="no-results" class="hidden text-center py-12">
              <svg class="mx-auto h-12 w-12 text-slate-500 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <h3 class="text-xl font-bold text-slate-100 mb-2">No terms found</h3>
              <p class="text-slate-400">Try adjusting your search criteria.</p>
            </div>
          </div>
        </div>

        <div class="hidden lg:block lg:col-span-1">
          <div class="sticky top-24">
            <Sidebar />
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const searchInput = document.getElementById('glossary-search') as HTMLInputElement;
      if (!searchInput) return;

      const glossaryGroups = document.querySelectorAll('.glossary-group');
      const noResults = document.getElementById('no-results');

      searchInput.addEventListener('input', (e) => {
        const query = (e.target as HTMLInputElement).value.toLowerCase();
        let totalMatches = 0;

        glossaryGroups.forEach((group) => {
          let groupHasMatch = false;
          const termCards = group.querySelectorAll('.glossary-term-card');

          termCards.forEach((card) => {
            const title = card.querySelector('.glossary-term-title')?.textContent?.toLowerCase() || '';
            const desc = card.querySelector('.glossary-term-desc')?.textContent?.toLowerCase() || '';
            
            if (title.includes(query) || desc.includes(query)) {
              (card as HTMLElement).style.display = 'block';
              groupHasMatch = true;
              totalMatches++;
            } else {
              (card as HTMLElement).style.display = 'none';
            }
          });

          (group as HTMLElement).style.display = groupHasMatch ? 'block' : 'none';
        });

        if (noResults) {
          noResults.style.display = totalMatches === 0 ? 'block' : 'none';
        }
      });
    });
  </script>
</BaseLayout>
