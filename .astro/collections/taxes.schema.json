{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "pubDate": {
      "type": "string",
      "format": "date-time"
    },
    "updatedDate": {
      "type": "string",
      "format": "date-time"
    },
    "heroImage": {
      "type": "string"
    },
    "heroImageLight": {
      "type": "string"
    },
    "heroImageDark": {
      "type": "string"
    },
    "author": {
      "default": "Get Global Yields Team",
      "type": "string"
    },
    "categories": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "canonicalURL": {
      "type": "string",
      "format": "uri"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "readingTime": {
      "type": "string"
    },
    "featured": {
      "type": "boolean"
    },
    "seo": {
      "type": "object",
      "properties": {
        "metaTitle": {
          "type": "string"
        },
        "metaDescription": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ogTitle": {
          "type": "string"
        },
        "ogDescription": {
          "type": "string"
        },
        "ogImage": {
          "type": "string"
        },
        "twitterCard": {
          "type": "string"
        }
      }
    },
    "schema": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string"
        },
        "headline": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "datePublished": {
          "type": "string"
        },
        "dateModified": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "mainEntityOfPage": {
          "type": "string"
        }
      }
    },
    "productName": {
      "type": "string"
    },
    "rating": {
      "type": "number"
    },
    "pros": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "cons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "affiliateLink": {
      "type": "string",
      "format": "uri"
    },
    "products": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "description",
    "pubDate"
  ]
}